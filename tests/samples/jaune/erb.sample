#                                                                 ^-- punctuation.accessor.ts
#                                                                    ^- string.quoted.double.ts
#                                                                    ^ punctuation.definition.string.begin.ts
#                                                                     ^ invalid.illegal.newline.ts
                   999.95 )
#<0------------------------ string.quoted.double.ts
#<0------------------------ string.quoted.single.ts
