-- | When performance is critical then use Data.Function.Uncurried
--<0-------------------------------------------------------------- comment.line.double-dash.purescript
--<0 punctuation.definition.comment.purescript
myAddFast :: Fn2 Int Int Int
--<0------------------------ meta.function.type-declaration.purescript
--<0----- entity.name.function.purescript
--        ^- keyword.other.double-colon.purescript
--           ^-- entity.name.type.purescript
--               ^-- entity.name.type.purescript
--                   ^-- entity.name.type.purescript
--                       ^-- entity.name.type.purescript
myAddFast = mkFn2 \x y → x + y
--        ^ keyword.operator.purescript
--                ^ keyword.operator.purescript
--                     ^ keyword.operator.purescript
--                         ^ keyword.operator.purescript

add10 :: Int -> Int
--<0--------------- meta.function.type-declaration.purescript
--<0- entity.name.function.purescript
--    ^- keyword.other.double-colon.purescript
--       ^-- entity.name.type.purescript
--           ^- keyword.other.arrow.purescript
--              ^-- entity.name.type.purescript
add10 = myAdd 10
--    ^ keyword.operator.purescript
--            ^- constant.numeric.decimal.purescript
--            ^- constant.numeric.decimal.purescript

modulo :: Int -> Int -> Int
--<0----------------------- meta.function.type-declaration.purescript
--<0-- entity.name.function.purescript
--     ^- keyword.other.double-colon.purescript
--        ^-- entity.name.type.purescript
--            ^- keyword.other.arrow.purescript
--               ^-- entity.name.type.purescript
--                   ^- keyword.other.arrow.purescript
--                      ^-- entity.name.type.purescript
modulo dvr dvd = dvd `mod` dvr
--             ^ keyword.operator.purescript
--                   ^---- keyword.operator.function.infix.purescript
--                   ^ punctuation.definition.entity.purescript
--                       ^ punctuation.definition.entity.purescript

isOdd :: Int -> Int
--<0--------------- meta.function.type-declaration.purescript
--<0- entity.name.function.purescript
--    ^- keyword.other.double-colon.purescript
--       ^-- entity.name.type.purescript
--           ^- keyword.other.arrow.purescript
--              ^-- entity.name.type.purescript
isOdd = modulo 2
--    ^ keyword.operator.purescript
--             ^ constant.numeric.decimal.purescript
--             ^ constant.numeric.decimal.purescript

getAllOdds :: List Int -> List Int
--<0------------------------------ meta.function.type-declaration.purescript
--<0------ entity.name.function.purescript
--         ^- keyword.other.double-colon.purescript
--            ^--- entity.name.type.purescript
--                 ^-- entity.name.type.purescript
--                     ^- keyword.other.arrow.purescript
--                        ^--- entity.name.type.purescript
--                             ^-- entity.name.type.purescript
getAllOdds = filter (\x -> isOdd x /= 0)
--         ^ keyword.operator.purescript
--                   ^ keyword.operator.purescript
--                      ^- keyword.other.arrow.purescript
--                                 ^- keyword.operator.purescript
--                                    ^ constant.numeric.decimal.purescript
--                                    ^ constant.numeric.decimal.purescript

regexString :: Regex
--<0---------------- meta.function.type-declaration.purescript
--<0------- entity.name.function.purescript
--          ^- keyword.other.double-colon.purescript
--             ^---- entity.name.type.purescript
regexString =
--          ^ keyword.operator.purescript
  unsafePartial
    case (regex "[aeiou]" (parseFlags "ig")) of
--  ^--- keyword.control.purescript
--              ^-------- string.quoted.double.purescript
--              ^ punctuation.definition.string.begin.purescript
--                      ^ punctuation.definition.string.end.purescript
--                                    ^--- string.quoted.double.purescript
--                                    ^ punctuation.definition.string.begin.purescript
--                                       ^ punctuation.definition.string.end.purescript
--                                           ^- keyword.control.purescript
      Right r -> r
--    ^---- entity.name.tag.purescript
--            ^- keyword.other.arrow.purescript

censor :: String -> String
--<0---------------------- meta.function.type-declaration.purescript
--<0-- entity.name.function.purescript
--     ^- keyword.other.double-colon.purescript
--        ^----- entity.name.type.purescript
--               ^- keyword.other.arrow.purescript
--                  ^----- entity.name.type.purescript
censor = replace regexString "*"
--     ^ keyword.operator.purescript
--                           ^-- string.quoted.double.purescript
--                           ^ punctuation.definition.string.begin.purescript
--                             ^ punctuation.definition.string.end.purescript

censorAll :: Array String -> Array String
--<0------------------------------------- meta.function.type-declaration.purescript
--<0----- entity.name.function.purescript
--        ^- keyword.other.double-colon.purescript
--           ^---- entity.name.type.purescript
--                 ^----- entity.name.type.purescript
--                        ^- keyword.other.arrow.purescript
--                           ^---- entity.name.type.purescript
--                                 ^----- entity.name.type.purescript
censorAll = map censor
--        ^ keyword.operator.purescript

main :: Effect Unit
--<0--------------- meta.function.type-declaration.purescript
--<0 entity.name.function.purescript
--   ^- keyword.other.double-colon.purescript
--      ^----- entity.name.type.purescript
--             ^--- entity.name.type.purescript
main = do
--   ^ keyword.operator.purescript
--     ^- keyword.control.purescript
  log "Build curried functions"
--    ^------------------------ string.quoted.double.purescript
--    ^ punctuation.definition.string.begin.purescript
--                            ^ punctuation.definition.string.end.purescript
  log "\nAdvantage 1: Partially applying functions"
--    ^-------------------------------------------- string.quoted.double.purescript
--    ^ punctuation.definition.string.begin.purescript
--     ^- constant.character.escape.purescript
--                                                ^ punctuation.definition.string.end.purescript
  log     $ "myAdd: " <> (show $ myAdd 2 2)
--        ^ keyword.operator.purescript
--          ^-------- string.quoted.double.purescript
--          ^ punctuation.definition.string.begin.purescript
--                  ^ punctuation.definition.string.end.purescript
--                    ^- keyword.operator.purescript
--                             ^ keyword.operator.purescript
--                                     ^ constant.numeric.decimal.purescript
--                                     ^ constant.numeric.decimal.purescript
--                                       ^ constant.numeric.decimal.purescript
--                                       ^ constant.numeric.decimal.purescript
  log "\nAdvantage 2: function types"
--    ^------------------------------ string.quoted.double.purescript
--    ^ punctuation.definition.string.begin.purescript
--     ^- constant.character.escape.purescript
--                                  ^ punctuation.definition.string.end.purescript
  -- notice key' == key ('a' == 'a'), so return Just 1
--<0 punctuation.whitespace.comment.leading.purescript
--^--------------------------------------------------- comment.line.double-dash.purescript
--^- punctuation.definition.comment.purescript
  logShow $ (insertDict 'a' (1::Int) emptyDict) 'a'
--        ^ keyword.operator.purescript
--                      ^-- string.quoted.single.purescript
--                      ^ punctuation.definition.string.begin.purescript
--                        ^ punctuation.definition.string.end.purescript
--                           ^ constant.numeric.decimal.purescript
--                           ^ constant.numeric.decimal.purescript
--                            ^- keyword.other.double-colon.purescript
--                              ^-- meta.type-signature.purescript
--                              ^-- entity.name.type.purescript
--                                              ^-- string.quoted.single.purescript
--                                              ^ punctuation.definition.string.begin.purescript
--                                                ^ punctuation.definition.string.end.purescript
  -- search for 'a' in Dict and return its value
--<0 punctuation.whitespace.comment.leading.purescript
--^--------------------------------------------- comment.line.double-dash.purescript
--^- punctuation.definition.comment.purescript
  logShow $ insertDict 'b' 2 (insertDict 'a' (1::Int) emptyDict) 'a'
--        ^ keyword.operator.purescript
--                     ^-- string.quoted.single.purescript
--                     ^ punctuation.definition.string.begin.purescript
--                       ^ punctuation.definition.string.end.purescript
--                         ^ constant.numeric.decimal.purescript
--                         ^ constant.numeric.decimal.purescript
--                                       ^-- string.quoted.single.purescript
--                                       ^ punctuation.definition.string.begin.purescript
--                                         ^ punctuation.definition.string.end.purescript
--                                            ^ constant.numeric.decimal.purescript
--                                            ^ constant.numeric.decimal.purescript
--                                             ^- keyword.other.double-colon.purescript
--                                               ^-- meta.type-signature.purescript
--                                               ^-- entity.name.type.purescript
--                                                               ^-- string.quoted.single.purescript
--                                                               ^ punctuation.definition.string.begin.purescript
--                                                                 ^ punctuation.definition.string.end.purescript
  -- the 'x' key is not in Dict, so fall back to Nothing
--<0 punctuation.whitespace.comment.leading.purescript
--^----------------------------------------------------- comment.line.double-dash.purescript
--^- punctuation.definition.comment.purescript
  logShow $ insertDict 'b' 2 (insertDict 'a' (1::Int) emptyDict) 'x'
--        ^ keyword.operator.purescript
--                     ^-- string.quoted.single.purescript
--                     ^ punctuation.definition.string.begin.purescript
--                       ^ punctuation.definition.string.end.purescript
--                         ^ constant.numeric.decimal.purescript
--                         ^ constant.numeric.decimal.purescript
--                                       ^-- string.quoted.single.purescript
--                                       ^ punctuation.definition.string.begin.purescript
--                                         ^ punctuation.definition.string.end.purescript
--                                            ^ constant.numeric.decimal.purescript
--                                            ^ constant.numeric.decimal.purescript
--                                             ^- keyword.other.double-colon.purescript
--                                               ^-- meta.type-signature.purescript
--                                               ^-- entity.name.type.purescript
--                                                               ^-- string.quoted.single.purescript
--                                                               ^ punctuation.definition.string.begin.purescript
--                                                                 ^ punctuation.definition.string.end.purescript
  log "\nCurrying Examples: add10, isOdd, isOdd21, getAllOdds"
--    ^------------------------------------------------------- string.quoted.double.purescript
--    ^ punctuation.definition.string.begin.purescript
--     ^- constant.character.escape.purescript
--                                                           ^ punctuation.definition.string.end.purescript
  logShow $ add10 2
--        ^ keyword.operator.purescript
--                ^ constant.numeric.decimal.purescript
--                ^ constant.numeric.decimal.purescript
  logShow $ isOdd 2
--        ^ keyword.operator.purescript
--                ^ constant.numeric.decimal.purescript
--                ^ constant.numeric.decimal.purescript
  logShow $ isOdd 21
--        ^ keyword.operator.purescript
--                ^- constant.numeric.decimal.purescript
--                ^- constant.numeric.decimal.purescript
  logShow $ getAllOdds (1 : 2 : 3 : 4 : Nil)
--        ^ keyword.operator.purescript
--                      ^ constant.numeric.decimal.purescript
--                      ^ constant.numeric.decimal.purescript
--                        ^ keyword.operator.purescript
--                          ^ constant.numeric.decimal.purescript
--                          ^ constant.numeric.decimal.purescript
--                            ^ keyword.operator.purescript
--                              ^ constant.numeric.decimal.purescript
--                              ^ constant.numeric.decimal.purescript
--                                ^ keyword.operator.purescript
--                                  ^ constant.numeric.decimal.purescript
--                                  ^ constant.numeric.decimal.purescript
--                                    ^ keyword.operator.purescript
--                                      ^-- entity.name.tag.purescript
  log "\nBuild up predicate functions"
--    ^------------------------------- string.quoted.double.purescript
--    ^ punctuation.definition.string.begin.purescript
--     ^- constant.character.escape.purescript
--                                   ^ punctuation.definition.string.end.purescript
  log $ censor "hello world"
--    ^ keyword.operator.purescript
--             ^------------ string.quoted.double.purescript
--             ^ punctuation.definition.string.begin.purescript
--                         ^ punctuation.definition.string.end.purescript
  logShow $ censorAll ["hello", "world"]
--        ^ keyword.operator.purescript
--                     ^------ string.quoted.double.purescript
--                     ^ punctuation.definition.string.begin.purescript
--                           ^ punctuation.definition.string.end.purescript
--                            ^ punctuation.separator.comma.purescript
--                              ^------ string.quoted.double.purescript
--                              ^ punctuation.definition.string.begin.purescript
--                                    ^ punctuation.definition.string.end.purescript
  log "\nUse Data.Function.Uncurried when performance is critical"
--    ^----------------------------------------------------------- string.quoted.double.purescript
--    ^ punctuation.definition.string.begin.purescript
--     ^- constant.character.escape.purescript
--                                                               ^ punctuation.definition.string.end.purescript
  logShow $ runFn2 myAddFast 10 10
--        ^ keyword.operator.purescript
--                           ^- constant.numeric.decimal.purescript
--                           ^- constant.numeric.decimal.purescript
--                              ^- constant.numeric.decimal.purescript
--                              ^- constant.numeric.decimal.purescript

