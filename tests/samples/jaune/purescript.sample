type Dict key value = key → Maybe value
--<0----------------------------------- meta.declaration.type.type.purescript
--<0 storage.type.data.purescript
--   ^------------- meta.type-signature.purescript
--   ^--- entity.name.type.purescript
--        ^-- variable.other.generic-type.purescript
--            ^---- variable.other.generic-type.purescript
--                  ^ keyword.operator.assignment.purescript
--                    ^-- variable.other.generic-type.purescript
--                        ^ keyword.other.arrow.purescript
--                          ^---- entity.name.type.purescript
--                                ^---- variable.other.generic-type.purescript

emptyDict :: ∀ k v. Dict k v
--<0------------------------ meta.function.type-declaration.purescript
--<0----- entity.name.function.purescript
--        ^- keyword.other.double-colon.purescript
--           ^ keyword.other.forall.purescript
--             ^ variable.other.generic-type.purescript
--               ^ variable.other.generic-type.purescript
--                ^ keyword.other.purescript
--                  ^--- entity.name.type.purescript
--                       ^ variable.other.generic-type.purescript
--                         ^ variable.other.generic-type.purescript
emptyDict _ = Nothing
--          ^ keyword.operator.purescript
--            ^------ entity.name.tag.purescript

insertDict :: ∀ k v. (Eq k) => k → v → Dict k v → Dict k v
--<0------------------------------------------------------ meta.function.type-declaration.purescript
--<0------ entity.name.function.purescript
--         ^- keyword.other.double-colon.purescript
--            ^ keyword.other.forall.purescript
--              ^ variable.other.generic-type.purescript
--                ^ variable.other.generic-type.purescript
--                 ^ keyword.other.purescript
--                   ^-------- meta.class-constraints.purescript
--                    ^--- meta.class-constraint.purescript
--                    ^- entity.name.type.purescript
--                       ^ variable.other.generic-type.purescript
--                          ^- keyword.other.big-arrow.purescript
--                             ^ variable.other.generic-type.purescript
--                               ^ keyword.other.arrow.purescript
--                                 ^ variable.other.generic-type.purescript
--                                   ^ keyword.other.arrow.purescript
--                                     ^--- entity.name.type.purescript
--                                          ^ variable.other.generic-type.purescript
--                                            ^ variable.other.generic-type.purescript
--                                              ^ keyword.other.arrow.purescript
--                                                ^--- entity.name.type.purescript
--                                                     ^ variable.other.generic-type.purescript
--                                                       ^ variable.other.generic-type.purescript
insertDict key value dict =
--                        ^ keyword.operator.purescript
  \key' → if key == key'
--^ keyword.operator.purescript
--      ^ keyword.operator.purescript
--        ^- keyword.control.purescript
--               ^- keyword.operator.purescript
            then (Just value)
--          ^--- keyword.control.purescript
--                ^--- entity.name.tag.purescript
            else dict key'
--          ^--- keyword.control.purescript


