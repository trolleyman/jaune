% grammar: source.matlab



clear
number = input('Give an integer: ');
%              ^------------------ string.quoted.single.matlab
%              ^ punctuation.definition.string.begin.matlab
%                                ^ punctuation.definition.string.end.matlab
remainder2 = rem(number,2);
%                       ^ constant.numeric.matlab
remainder3 = rem(number,3);
%                       ^ constant.numeric.matlab

if remainder2==0 & remainder3==0
%<0----------------------------- meta.if.matlab
%<0 keyword.control.if.matlab
%              ^ constant.numeric.matlab
%                ^ keyword.operator.symbols.matlab
%                              ^ constant.numeric.matlab
    'Your number is divisible by both 2 and 3'
%<0------------------------------------------- meta.if.matlab
%   ^----------------------------------------- string.quoted.single.matlab
%   ^ punctuation.definition.string.begin.matlab
else
%<0- meta.if.matlab
%<0- string.quoted.single.matlab
    if remainder2==0
%<0----------------- meta.if.matlab
%<0----------------- string.quoted.single.matlab
        'Your number is divisble by 2 but not by 3'
%<0------------------------------------------------ meta.if.matlab
%<0------------------------------------------------ string.quoted.single.matlab
%       ^ invalid.illegal.unescaped-quote.matlab
    else
%<0----- meta.if.matlab
%<0----- string.quoted.single.matlab
        if remainder3==0
%<0--------------------- meta.if.matlab
%<0--------------------- string.quoted.single.matlab
            'Your number is divisible by 3 but not by 2'
%<0----------------------------------------------------- meta.if.matlab
%<0----------------------------------------------------- string.quoted.single.matlab
%           ^ invalid.illegal.unescaped-quote.matlab
        else
%<0--------- meta.if.matlab
%<0--------- string.quoted.single.matlab
            'Your number is not divisible by either 2 or 3'
%<0-------------------------------------------------------- meta.if.matlab
%<0-------------------------------------------------------- string.quoted.single.matlab
%           ^ invalid.illegal.unescaped-quote.matlab
        end
%<0-------- meta.if.matlab
%<0-------- string.quoted.single.matlab
    end
%<0---- meta.if.matlab
%<0---- string.quoted.single.matlab
end
%<0 meta.if.matlab
%<0 string.quoted.single.matlab

% From https://www.math.colostate.edu/~yzhou/course/matlab_doc/matlab_programming_intro.html
%<0----------------------------------------------------------------------------------------- meta.if.matlab
%<0----------------------------------------------------------------------------------------- string.quoted.single.matlab
