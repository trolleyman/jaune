//           ^ punctuation.definition.string.begin
//                      ^ punctuation.definition.string.end
	_name:      ID
//<0----------- meta.struct
//<1-- variable.other
//    ^ punctuation.colon
//           ^- variable.other
	spec: replicas: *1 | int
//<0--------------------- meta.struct
//<1- variable.other
