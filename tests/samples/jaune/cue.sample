//                          ^---- variable.other
//                               ^ punctuation.definition.struct.end
//                                ^ punctuation.section.brackets.end
	}
//<0 meta.struct
//<0 meta.struct
//<1 punctuation.definition.struct.end
}
//<0 meta.struct
//<0 punctuation.definition.struct.end

// Define the _export option and set the default to true
//<0---------------------------------------------------- comment.line
//<0 punctuation.definition.comment
// for all ports defined in all containers.
//<0--------------------------------------- comment.line
//<0 punctuation.definition.comment
_spec: spec: template: spec: containers: [...{
//<0- variable.other
//   ^ punctuation.colon
//     ^--- variable.other
//         ^ punctuation.colon
//           ^------- variable.other
//                   ^ punctuation.colon
//                     ^--- variable.other
//                         ^ punctuation.colon
//                           ^--------- variable.other
//                                     ^ punctuation.colon
//                                       ^---- meta.brackets
//                                       ^ punctuation.section.brackets.begin
//                                        ^-- punctuation.ellipsis
//                                           ^ meta.struct
//                                           ^ punctuation.definition.struct.begin
	ports: [...{
//<0--------- meta.brackets
//<0--------- meta.struct
//<1-- variable.other
//    ^ punctuation.colon
//      ^---- meta.brackets
//      ^ punctuation.section.brackets.begin
//       ^-- punctuation.ellipsis
//          ^ meta.struct
//          ^ punctuation.definition.struct.begin
		_export: *true | false // include the port in the service
//<0------------------------------------------------------- meta.brackets
//<0------------------------------------------------------- meta.struct
//<0------------------------------------------------------- meta.brackets
//<0------------------------------------------------------- meta.struct
//^------ variable.other
//       ^ punctuation.colon
//         ^ keyword.operator
//          ^--- constant.language.bool
//               ^ keyword.operator.set
//                 ^---- constant.language.bool
//                       ^--------------------------------- comment.line
//                       ^- punctuation.definition.comment
	}]
//<0 meta.brackets
//<0 meta.struct
//<0 meta.brackets
//<0 meta.struct
//<1 punctuation.definition.struct.end
//^ punctuation.section.brackets.end
}]
//<0 meta.brackets
//<0 meta.struct
//<0 punctuation.definition.struct.end
//<1 punctuation.section.brackets.end

for x in [deployment, daemonSet, statefulSet] for k, v in x {
//<0 keyword.control.for
//  ^ variable.other
//    ^- keyword.control.in
//       ^----------------------------------- meta.brackets
//       ^ punctuation.section.brackets.begin
//        ^--------- variable.other
//                  ^ punctuation.separator
//                    ^-------- variable.other
//                             ^ punctuation.separator
//                               ^---------- variable.other
//                                          ^ punctuation.section.brackets.end
//                                            ^-- keyword.control.for
//                                                ^ variable.other
//                                                 ^ punctuation.separator
//                                                   ^ variable.other
//                                                     ^- keyword.control.in
//                                                        ^ variable.other
//                                                          ^ meta.struct
//                                                          ^ punctuation.definition.struct.begin
	service: "\(k)": {
//<0--------------- meta.struct
//<1---- variable.other
//      ^ punctuation.colon
//        ^----- meta.string
//        ^ punctuation.definition.string.begin
//         ^--- meta.interpolation
//         ^- punctuation.section.interpolation.begin
//           ^ variable.other
//            ^ punctuation.section.interpolation.end
//             ^ punctuation.definition.string.end
//              ^ punctuation.colon
//                ^ meta.struct
//                ^ punctuation.definition.struct.begin
		spec: selector: v.spec.template.metadata.labels
//<0--------------------------------------------- meta.struct
//<0--------------------------------------------- meta.struct
//^--- variable.other
//    ^ punctuation.colon
//      ^------- variable.other
//              ^ punctuation.colon
//                ^ variable.other
//                 ^ punctuation.accessor
//                  ^--- variable.other.member
//                      ^ punctuation.accessor
//                       ^------- variable.other.member
//                               ^ punctuation.accessor
//                                ^------- variable.other.member
//                                        ^ punctuation.accessor
//                                         ^----- variable.other.member

		spec: ports: [
//<0------------ meta.struct
//<0------------ meta.struct
//^--- variable.other
//    ^ punctuation.colon
//      ^---- variable.other
//           ^ punctuation.colon
//             ^ meta.brackets
//             ^ punctuation.section.brackets.begin
			for c in v.spec.template.spec.containers
//<0--------------------------------------- meta.struct
//<0--------------------------------------- meta.struct
//<0--------------------------------------- meta.brackets
// ^-- keyword.control.for
//     ^ variable.other
//       ^- keyword.control.in
//          ^ variable.other
//           ^ punctuation.accessor
//            ^--- variable.other.member
//                ^ punctuation.accessor
//                 ^------- variable.other.member
//                         ^ punctuation.accessor
//                          ^--- variable.other.member
//                              ^ punctuation.accessor
//                               ^--------- variable.other.member
			for p in c.ports
//<0--------------- meta.struct
//<0--------------- meta.struct
//<0--------------- meta.brackets
// ^-- keyword.control.for
//     ^ variable.other
//       ^- keyword.control.in
//          ^ variable.other
//           ^ punctuation.accessor
//            ^---- variable.other.member
			if p._export {
//<0------------- meta.struct
//<0------------- meta.struct
//<0------------- meta.brackets
// ^- keyword.control.conditional
//    ^ variable.other
//     ^ punctuation.accessor
//      ^------ variable.other.member
//              ^ meta.struct
//              ^ punctuation.definition.struct.begin
				let Port = p.containerPort // Port is an alias
//<0---------------------------------------------- meta.struct
//<0---------------------------------------------- meta.struct
//<0---------------------------------------------- meta.brackets
//<0---------------------------------------------- meta.struct
//  ^-- keyword.control.let
//      ^--- variable.other
//           ^ punctuation.bind
//             ^ variable.other
//              ^ punctuation.accessor
//               ^------------ variable.other.member
//                             ^------------------ comment.line
//                             ^- punctuation.definition.comment
				port:       *Port | int
//<0----------------------- meta.struct
//<0----------------------- meta.struct
//<0----------------------- meta.brackets
//<0----------------------- meta.struct
//  ^--- variable.other
//      ^ punctuation.colon
//              ^ keyword.operator
//               ^--- variable.other
//                    ^ keyword.operator.set
//                      ^-- support.type
				targetPort: *Port | int
//<0----------------------- meta.struct
//<0----------------------- meta.struct
//<0----------------------- meta.brackets
//<0----------------------- meta.struct
//  ^--------- variable.other
//            ^ punctuation.colon
//              ^ keyword.operator
//               ^--- variable.other
//                    ^ keyword.operator.set
//                      ^-- support.type
			},
//<0- meta.struct
//<0- meta.struct
//<0- meta.brackets
//<0 meta.struct
// ^ punctuation.definition.struct.end
//  ^ punctuation.separator
		]
//<0 meta.struct
//<0 meta.struct
//<0 meta.brackets
//^ punctuation.section.brackets.end
	}
//<0 meta.struct
//<0 meta.struct
//<1 punctuation.definition.struct.end
}
//<0 meta.struct
//<0 punctuation.definition.struct.end
