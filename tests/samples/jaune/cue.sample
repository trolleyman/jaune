	apiVersion: "apps/v1"
//<0------------------ meta.struct
//<1------- variable.other
//         ^ punctuation.colon
//           ^-------- meta.string
//           ^ punctuation.definition.string.begin
//                   ^ punctuation.definition.string.end
	kind:       "Deployment"
//<0--------------------- meta.struct
//<1- variable.other
//   ^ punctuation.colon
