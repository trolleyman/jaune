// grammar: source.cue

package kube
//<0--- keyword.other.package
//      ^--- entity.name.namespace

service: [ID=_]: {
//<0--- variable.other
//     ^ punctuation.colon
//       ^----- meta.brackets
//       ^ punctuation.section.brackets.begin
//        ^- variable.other
//          ^ punctuation.alias
//           ^ constant.language.top
//            ^ punctuation.section.brackets.end
//             ^ punctuation.colon
//               ^ meta.struct
//               ^ punctuation.definition.struct.begin
	apiVersion: "v1"
//<0------------- meta.struct
//<1------- variable.other
//         ^ punctuation.colon
//           ^--- meta.string
//           ^ punctuation.definition.string.begin
//              ^ punctuation.definition.string.end
	kind:       "Service"
//<0------------------ meta.struct
//<1- variable.other
//   ^ punctuation.colon
//           ^-------- meta.string
//           ^ punctuation.definition.string.begin
//                   ^ punctuation.definition.string.end
	metadata: {
//<0-------- meta.struct
//<1----- variable.other
//       ^ punctuation.colon
//         ^ meta.struct
//         ^ punctuation.definition.struct.begin
		name: ID
//<0------ meta.struct
//<0------ meta.struct
//^--- variable.other
//    ^ punctuation.colon
//      ^- variable.other
		labels: {
//<0------- meta.struct
//<0------- meta.struct
//^----- variable.other
//      ^ punctuation.colon
//        ^ meta.struct
//        ^ punctuation.definition.struct.begin
			app:       ID         // by convention
//<0------------------------------------- meta.struct
//<0------------------------------------- meta.struct
//<0------------------------------------- meta.struct
// ^-- variable.other
//    ^ punctuation.colon
//            ^- variable.other
//                       ^--------------- comment.line
//                       ^- punctuation.definition.comment
			domain:    "prod"     // always the same in the given files
//<0---------------------------------------------------------- meta.struct
//<0---------------------------------------------------------- meta.struct
//<0---------------------------------------------------------- meta.struct
// ^----- variable.other
//       ^ punctuation.colon
//            ^----- meta.string
//            ^ punctuation.definition.string.begin
//                 ^ punctuation.definition.string.end
//                       ^------------------------------------ comment.line
//                       ^- punctuation.definition.comment
			component: #Component // varies per directory
//<0-------------------------------------------- meta.struct
//<0-------------------------------------------- meta.struct
//<0-------------------------------------------- meta.struct
// ^-------- variable.other
//          ^ punctuation.colon
//            ^--------- variable.other
//                       ^---------------------- comment.line
//                       ^- punctuation.definition.comment
		}
//<0 meta.struct
//<0 meta.struct
//<0 meta.struct
//^ punctuation.definition.struct.end
	}
//<0 meta.struct
//<0 meta.struct
//<1 punctuation.definition.struct.end
	spec: {
//<0---- meta.struct
//<1- variable.other
//   ^ punctuation.colon
//     ^ meta.struct
//     ^ punctuation.definition.struct.begin
		// Any port has the following properties.
//<0--------------------------------------- meta.struct
//<0--------------------------------------- meta.struct
//^---------------------------------------- comment.line
//^- punctuation.definition.comment
		ports: [...{
//<0---------- meta.struct
//<0---------- meta.struct
//^---- variable.other
//     ^ punctuation.colon
//       ^---- meta.brackets
//       ^ punctuation.section.brackets.begin
//        ^-- punctuation.ellipsis
//           ^ meta.struct
//           ^ punctuation.definition.struct.begin
			port:     int
//<0------------ meta.struct
//<0------------ meta.struct
//<0------------ meta.brackets
//<0------------ meta.struct
// ^--- variable.other
//     ^ punctuation.colon
//           ^-- support.type
			protocol: *"TCP" | "UDP" // from the Kubernetes definition
//<0--------------------------------------------------------- meta.struct
//<0--------------------------------------------------------- meta.struct
//<0--------------------------------------------------------- meta.brackets
//<0--------------------------------------------------------- meta.struct
// ^------- variable.other
//         ^ punctuation.colon
//           ^ keyword.operator
//            ^---- meta.string
//            ^ punctuation.definition.string.begin
//                ^ punctuation.definition.string.end
//                  ^ keyword.operator.set
//                    ^---- meta.string
//                    ^ punctuation.definition.string.begin
//                        ^ punctuation.definition.string.end
//                          ^-------------------------------- comment.line
//                          ^- punctuation.definition.comment
			name:     string | *"client"
//<0--------------------------- meta.struct
//<0--------------------------- meta.struct
//<0--------------------------- meta.brackets
//<0--------------------------- meta.struct
// ^--- variable.other
//     ^ punctuation.colon
//           ^----- support.type
//                  ^ keyword.operator.set
//                    ^ keyword.operator
//                     ^------- meta.string
//                     ^ punctuation.definition.string.begin
//                            ^ punctuation.definition.string.end
		}]
//<0 meta.struct
//<0 meta.struct
//<0 meta.brackets
//<0 meta.struct
//^ punctuation.definition.struct.end
// ^ punctuation.section.brackets.end
		selector: metadata.labels // we want those to be the same
//<0------------------------------------------------------- meta.struct
//<0------------------------------------------------------- meta.struct
//^------- variable.other
//        ^ punctuation.colon
//          ^------- variable.other
//                  ^ punctuation.accessor
//                   ^----- variable.other.member
//                          ^------------------------------ comment.line
//                          ^- punctuation.definition.comment
	}
//<0 meta.struct
//<0 meta.struct
//<1 punctuation.definition.struct.end
}
//<0 meta.struct
//<0 punctuation.definition.struct.end

deployment: [ID=_]: {
//<0------ variable.other
//        ^ punctuation.colon
//          ^----- meta.brackets
//          ^ punctuation.section.brackets.begin
//           ^- variable.other
//             ^ punctuation.alias
//              ^ constant.language.top
//               ^ punctuation.section.brackets.end
//                ^ punctuation.colon
//                  ^ meta.struct
//                  ^ punctuation.definition.struct.begin
	apiVersion: "apps/v1"
//<0------------------ meta.struct
//<1------- variable.other
//         ^ punctuation.colon
//           ^-------- meta.string
//           ^ punctuation.definition.string.begin
//                   ^ punctuation.definition.string.end
	kind:       "Deployment"
//<0--------------------- meta.struct
//<1- variable.other
