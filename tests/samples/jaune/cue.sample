//             ^ punctuation.colon
//               ^- variable.other
	spec: {
//<0---- meta.struct
//<1- variable.other
//   ^ punctuation.colon
//     ^ meta.struct
//     ^ punctuation.definition.struct.begin
		// 1 is the default, but we allow any number
//<0------------------------------------------ meta.struct
//<0------------------------------------------ meta.struct
//^------------------------------------------- comment.line
//^- punctuation.definition.comment
		replicas: *1 | int
//<0---------------- meta.struct
//<0---------------- meta.struct
//^------- variable.other
//        ^ punctuation.colon
//          ^ keyword.operator
//           ^ constant.numeric.integer.decimal
//             ^ keyword.operator.set
//               ^-- support.type
		template: {
//<0--------- meta.struct
//<0--------- meta.struct
//^------- variable.other
//        ^ punctuation.colon
//          ^ meta.struct
//          ^ punctuation.definition.struct.begin
			metadata: labels: {
//<0------------------ meta.struct
//<0------------------ meta.struct
//<0------------------ meta.struct
// ^------- variable.other
//         ^ punctuation.colon
//           ^----- variable.other
//                 ^ punctuation.colon
//                   ^ meta.struct
//                   ^ punctuation.definition.struct.begin
				app:       ID
//<0------------- meta.struct
//<0------------- meta.struct
//<0------------- meta.struct
//<0------------- meta.struct
//  ^-- variable.other
//     ^ punctuation.colon
//             ^- variable.other
				domain:    "prod"
//<0----------------- meta.struct
//<0----------------- meta.struct
//<0----------------- meta.struct
//<0----------------- meta.struct
//  ^----- variable.other
//        ^ punctuation.colon
//             ^----- meta.string
//             ^ punctuation.definition.string.begin
//                  ^ punctuation.definition.string.end
				component: #Component
//<0--------------------- meta.struct
//<0--------------------- meta.struct
//<0--------------------- meta.struct
//<0--------------------- meta.struct
//  ^-------- variable.other
//           ^ punctuation.colon
//             ^--------- variable.other
			}
//<0 meta.struct
//<0 meta.struct
//<0 meta.struct
//<0 meta.struct
// ^ punctuation.definition.struct.end
			// we always have one namesake container
//<0--------------------------------------- meta.struct
//<0--------------------------------------- meta.struct
//<0--------------------------------------- meta.struct
// ^--------------------------------------- comment.line
// ^- punctuation.definition.comment
			spec: containers: [{name: ID}]
//<0----------------------------- meta.struct
//<0----------------------------- meta.struct
//<0----------------------------- meta.struct
// ^--- variable.other
//     ^ punctuation.colon
//       ^--------- variable.other
//                 ^ punctuation.colon
//                   ^----------- meta.brackets
//                   ^ punctuation.section.brackets.begin
//                    ^--------- meta.struct
//                    ^ punctuation.definition.struct.begin
//                     ^--- variable.other
//                         ^ punctuation.colon
//                           ^- variable.other
//                             ^ punctuation.definition.struct.end
//                              ^ punctuation.section.brackets.end
		}
//<0 meta.struct
//<0 meta.struct
//<0 meta.struct
//^ punctuation.definition.struct.end
	}
//<0 meta.struct
//<0 meta.struct
//<1 punctuation.definition.struct.end
}
//<0 meta.struct
//<0 punctuation.definition.struct.end

#Component: string
//<0------ variable.other
