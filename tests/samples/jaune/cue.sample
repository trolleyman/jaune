configMap: [ID=_]: {
//<0----- variable.other
//       ^ punctuation.colon
//         ^----- meta.brackets
//         ^ punctuation.section.brackets.begin
//          ^- variable.other
//            ^ punctuation.alias
//             ^ constant.language.top
//              ^ punctuation.section.brackets.end
//               ^ punctuation.colon
//                 ^ meta.struct
//                 ^ punctuation.definition.struct.begin
	metadata: name: ID
//<0--------------- meta.struct
//<1----- variable.other
//       ^ punctuation.colon
//         ^--- variable.other
//             ^ punctuation.colon
//               ^- variable.other
	metadata: labels: component: #Component
//<0------------------------------------ meta.struct
//<1----- variable.other
//       ^ punctuation.colon
//         ^----- variable.other
//               ^ punctuation.colon
//                 ^-------- variable.other
//                          ^ punctuation.colon
//                            ^--------- variable.other
}
//<0 meta.struct
//<0 punctuation.definition.struct.end

_spec: {
//<0- variable.other
//   ^ punctuation.colon
//     ^ meta.struct
//     ^ punctuation.definition.struct.begin
	_name: string
//<0---------- meta.struct
//<1-- variable.other
//    ^ punctuation.colon
//      ^----- support.type

	metadata: name: _name
//<0------------------ meta.struct
//<1----- variable.other
//       ^ punctuation.colon
//         ^--- variable.other
//             ^ punctuation.colon
//               ^---- variable.other
	metadata: labels: component: #Component
//<0------------------------------------ meta.struct
//<1----- variable.other
//       ^ punctuation.colon
//         ^----- variable.other
//               ^ punctuation.colon
//                 ^-------- variable.other
//                          ^ punctuation.colon
//                            ^--------- variable.other
	spec: selector: {}
//<0--------------- meta.struct
//<1- variable.other
//   ^ punctuation.colon
//     ^------- variable.other
//             ^ punctuation.colon
//               ^- meta.struct
//               ^ punctuation.definition.struct.begin
//                ^ punctuation.definition.struct.end
	spec: template: {
//<0-------------- meta.struct
//<1- variable.other
//   ^ punctuation.colon
//     ^------- variable.other
//             ^ punctuation.colon
//               ^ meta.struct
//               ^ punctuation.definition.struct.begin
		metadata: labels: {
//<0----------------- meta.struct
//<0----------------- meta.struct
//^------- variable.other
//        ^ punctuation.colon
//          ^----- variable.other
//                ^ punctuation.colon
//                  ^ meta.struct
//                  ^ punctuation.definition.struct.begin
			app:       _name
//<0--------------- meta.struct
//<0--------------- meta.struct
//<0--------------- meta.struct
// ^-- variable.other
//    ^ punctuation.colon
//            ^---- variable.other
			component: #Component
//<0-------------------- meta.struct
//<0-------------------- meta.struct
//<0-------------------- meta.struct
// ^-------- variable.other
//          ^ punctuation.colon
//            ^--------- variable.other
			domain:    "prod"
//<0---------------- meta.struct
//<0---------------- meta.struct
//<0---------------- meta.struct
// ^----- variable.other
//       ^ punctuation.colon
//            ^----- meta.string
//            ^ punctuation.definition.string.begin
//                 ^ punctuation.definition.string.end
		}
//<0 meta.struct
//<0 meta.struct
//<0 meta.struct
//^ punctuation.definition.struct.end
		spec: containers: [{name: _name}]
//<0------------------------------- meta.struct
//<0------------------------------- meta.struct
//^--- variable.other
//    ^ punctuation.colon
//      ^--------- variable.other
//                ^ punctuation.colon
//                  ^-------------- meta.brackets
//                  ^ punctuation.section.brackets.begin
//                   ^------------ meta.struct
//                   ^ punctuation.definition.struct.begin
