;                       ^----------- entity.name.function.symbol.fennel
;                                    ^- variable.other.fennel
;                                      ^ punctuation.paren.close.fennel
;                                       ^ punctuation.paren.close.fennel
          y (+ py (* dy player.speed dt))]
;<0--------------------------------------- sexp.fennel
;<0--------------------------------------- sexp.fennel
;<0--------------------------------------- sexp.fennel
;<0--------------------------------------- meta.vector.fennel
;         ^ variable.other.fennel
;           ^---------------------------- sexp.fennel
