;                 ^----- variable.other.fennel
          x (+ px (* dx player.speed dt))
;<0-------------------------------------- sexp.fennel
;<0-------------------------------------- sexp.fennel
;<0-------------------------------------- sexp.fennel
;<0-------------------------------------- meta.vector.fennel
;         ^ variable.other.fennel
;           ^---------------------------- sexp.fennel
