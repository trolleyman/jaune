  (when (love.keyboard.isDown key)
;<0------------------------------- sexp.fennel
; ^------------------------------- sexp.fennel
; ^ punctuation.paren.open.fennel
;  ^--- keyword.special.fennel
;       ^------------------------- sexp.fennel
;       ^ punctuation.paren.open.fennel
;        ^------------------- entity.name.function.symbol.fennel
;                             ^-- variable.other.fennel
;                                ^ punctuation.paren.close.fennel
    (let [[px py] player
;<0--------------------- sexp.fennel
;<0--------------------- sexp.fennel
;   ^------------------- sexp.fennel
;   ^ punctuation.paren.open.fennel
;    ^-- keyword.special.fennel
