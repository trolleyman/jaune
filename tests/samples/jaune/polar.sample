# grammar: source.polar

actor User { }
actor Group { }

resource Organization { 
    permissions = [
        "read",
        "read_details",
        "view_members",
        "manage_members",
        "set_default_role",
        "create_repositories",
        "delete"
    ];
    roles = ["admin", "member"];

    "read_details" if "member";
#                  ^- keyword.control.if
#                     ^------- string.quoted.double
    "view_members" if "member";
#                  ^- keyword.control.if
#                     ^------- string.quoted.double
    "create_repositories" if "member";
#                         ^- keyword.control.if
#                            ^------- string.quoted.double

    "member" if "admin";
#            ^- keyword.control.if
#               ^------ string.quoted.double
    "manage_members" if "admin";
#                    ^- keyword.control.if
#                       ^------ string.quoted.double
    "set_default_role" if "admin";
#                      ^- keyword.control.if
#                         ^------ string.quoted.double
    "delete" if "admin";
#            ^- keyword.control.if
#               ^------ string.quoted.double
}

resource Repository { 
    permissions = [
        "read", "create", "update", "delete",
        "invite", "write",
        "manage_jobs", "manage_issues", "create_issues",
        "view_members", "manage_members"
    ];
    roles = ["reader", "admin", "maintainer", "editor"];
    relations = { organization: Organization };

    "reader" if "member" on "organization";
#            ^- keyword.control.if
#               ^------- string.quoted.double
#                        ^- constant.character
#                           ^------------- string.quoted.double
    "admin" if "admin" on "organization";
#           ^- keyword.control.if
#              ^------ string.quoted.double
#                      ^- constant.character
#                         ^------------- string.quoted.double
    "reader" if "editor";
#            ^- keyword.control.if
#               ^------- string.quoted.double
    "editor" if "maintainer";
#            ^- keyword.control.if
#               ^----------- string.quoted.double
    "maintainer" if "admin";
#                ^- keyword.control.if
#                   ^------ string.quoted.double

    # reader permissions
#   ^------------------- comment.line.number-sign
    "read" if "reader";
#          ^- keyword.control.if
#             ^------- string.quoted.double
    "create_issues" if "reader";
#                   ^- keyword.control.if
#                      ^------- string.quoted.double

    # editor permissions
#   ^------------------- comment.line.number-sign
    "write" if "editor";
#           ^- keyword.control.if
#              ^------- string.quoted.double
    "manage_jobs" if "editor";
#                 ^- keyword.control.if
#                    ^------- string.quoted.double
    "manage_issues" if "editor";
#                   ^- keyword.control.if
#                      ^------- string.quoted.double
    "view_members" if "maintainer";
#                  ^- keyword.control.if
#                     ^----------- string.quoted.double

    # admin permissions
#   ^------------------ comment.line.number-sign
    "manage_members" if "admin";
#                    ^- keyword.control.if
#                       ^------ string.quoted.double
    "update" if "admin";
#            ^- keyword.control.if
#               ^------ string.quoted.double
    "delete" if "admin";
#            ^- keyword.control.if
#               ^------ string.quoted.double
    "invite" if "admin" ;
#            ^- keyword.control.if
#               ^------ string.quoted.double
}

resource Issue { 
    permissions = ["read", "comment", "close"];
    roles = ["reader", "admin", "creator"];
    relations = { repository: Repository };

    "reader" if "reader" on "repository";
#            ^- keyword.control.if
#               ^------- string.quoted.double
#                        ^- constant.character
#                           ^----------- string.quoted.double
    "admin" if "admin" on "repository";
#           ^- keyword.control.if
#              ^------ string.quoted.double
#                      ^- constant.character
#                         ^----------- string.quoted.double

    "read" if "reader";
#          ^- keyword.control.if
#             ^------- string.quoted.double
    "comment" if "admin";
#             ^- keyword.control.if
#                ^------ string.quoted.double
    "close" if "creator";
#           ^- keyword.control.if
#              ^-------- string.quoted.double
    "close" if "admin";
#           ^- keyword.control.if
#              ^------ string.quoted.double
    
}

has_permission(_: Actor, "read", repo: Repository) if
#<0----------- support.function.rule
#                 ^---- entity.name.type.resource
#                      ^ punctuation.separator.sequence.list
#                        ^----- string.quoted.double
#                              ^ punctuation.separator.sequence.list
#                                      ^--------- entity.name.type.resource
#                                                  ^- keyword.control.if
    is_public(repo);
#            ^----- meta.parens


has_permission(actor: Actor, "delete", repo: Repository) if
#<0----------- support.function.rule
#                     ^---- entity.name.type.resource
#                          ^ punctuation.separator.sequence.list
#                            ^------- string.quoted.double
#                                    ^ punctuation.separator.sequence.list
#                                            ^--------- entity.name.type.resource
#                                                        ^- keyword.control.if
    has_role(actor, "member", repo) and
#           ^---------------------- meta.parens
#                   ^------- string.quoted.double
#                                   ^-- constant.character
    is_protected(repo, false);
#               ^------------ meta.parens
#                      ^---- constant.language.boolean


# readers can only comment on open issues
#<0-------------------------------------- comment.line.number-sign
has_permission(actor: Actor, "comment", issue: Issue) if
#<0----------- support.function.rule
#                     ^---- entity.name.type.resource
#                          ^ punctuation.separator.sequence.list
#                            ^-------- string.quoted.double
#                                     ^ punctuation.separator.sequence.list
#                                              ^---- entity.name.type.resource
#                                                     ^- keyword.control.if
    has_permission(actor, "read", issue) and
#                 ^--------------------- meta.parens
#                         ^----- string.quoted.double
#                                        ^-- constant.character
    is_closed(issue, false);
#            ^------------- meta.parens
#                    ^---- constant.language.boolean


# Misc rules:
#<0---------- comment.line.number-sign
## All organizations are public
#<0---------------------------- comment.line.number-sign
has_permission(_: User, "read", _: Organization);
#<0----------- support.function.rule
#                 ^--- entity.name.type.resource
#                     ^ punctuation.separator.sequence.list
#                       ^----- string.quoted.double
#                             ^ punctuation.separator.sequence.list
#                                  ^----------- entity.name.type.resource
has_permission(_: User, "create", "Organization");
#<0----------- support.function.rule
#                 ^--- entity.name.type.resource
#                     ^ punctuation.separator.sequence.list
#                       ^------- string.quoted.double
#                               ^ punctuation.separator.sequence.list
#                                 ^------------- string.quoted.double
## Users can read all users
#<0------------------------ comment.line.number-sign
has_permission(_: User, "read", _: User);
#<0----------- support.function.rule
#                 ^--- entity.name.type.resource
#                     ^ punctuation.separator.sequence.list
#                       ^----- string.quoted.double
#                             ^ punctuation.separator.sequence.list
#                                  ^--- entity.name.type.resource
## Users can only read their own profiles
#<0-------------------------------------- comment.line.number-sign
has_permission(user: User, "read_profile", user: User);
#<0----------- support.function.rule
#                    ^--- entity.name.type.resource
#                        ^ punctuation.separator.sequence.list
#                          ^------------- string.quoted.double
#                                        ^ punctuation.separator.sequence.list
#                                                ^--- entity.name.type.resource


# Complex rules
#<0------------ comment.line.number-sign


# Actors inherit roles from groups
#<0------------------------------- comment.line.number-sign
has_role(user: User, role: String, resource: Resource) if
#<0----- support.function.rule
#              ^--- entity.name.type.resource
#                  ^ punctuation.separator.sequence.list
#                          ^----- entity.name.type.resource
#                                ^ punctuation.separator.sequence.list
#                                            ^------- entity.name.type.resource
#                                                      ^- keyword.control.if
    group matches Group and
#         ^------ constant.character
#                       ^-- constant.character
    has_group(user, group) and
#            ^------------ meta.parens
#                          ^-- constant.character
    has_role(group, role, resource);
#           ^---------------------- meta.parens

# Nested group
#<0----------- comment.line.number-sign
has_group(user: User, group: Group) if
#<0------ support.function.rule
#               ^--- entity.name.type.resource
#                   ^ punctuation.separator.sequence.list
#                            ^---- entity.name.type.resource
#                                   ^- keyword.control.if
    g matches Group and
#     ^------ constant.character
#                   ^-- constant.character
    has_group(user, g) and
#            ^-------- meta.parens
#                      ^-- constant.character
    has_group(g, group);
#            ^--------- meta.parens

# A custom role is defined by the permissions it grants
#<0---------------------------------------------------- comment.line.number-sign
has_permission(actor: Actor, action: String, org: Organization) if
#<0----------- support.function.rule
#                     ^---- entity.name.type.resource
#                          ^ punctuation.separator.sequence.list
#                                    ^----- entity.name.type.resource
#                                          ^ punctuation.separator.sequence.list
#                                                 ^----------- entity.name.type.resource
#                                                               ^- keyword.control.if
    role matches Role and
#        ^------ constant.character
#                     ^-- constant.character
    has_role(actor, role, org) and
#           ^----------------- meta.parens
#                              ^-- constant.character
    grants_permission(role, action);
#                    ^------------- meta.parens

has_role(actor: Actor, role: String, repo: Repository) if
#<0----- support.function.rule
#               ^---- entity.name.type.resource
#                    ^ punctuation.separator.sequence.list
#                            ^----- entity.name.type.resource
#                                  ^ punctuation.separator.sequence.list
#                                          ^--------- entity.name.type.resource
#                                                      ^- keyword.control.if
    org matches Organization and
#       ^------ constant.character
#                            ^-- constant.character
    has_relation(repo, "organization", org) and
#               ^-------------------------- meta.parens
#                      ^------------- string.quoted.double
#                                           ^-- constant.character
    has_default_role(org, role) and
#                   ^---------- meta.parens
#                               ^-- constant.character
    has_role(actor, "member", org);
#           ^--------------------- meta.parens
#                   ^------- string.quoted.double

# Policy tests
#<0----------- comment.line.number-sign
# Organization members inherit the read permission
#<0----------------------------------------------- comment.line.number-sign
# on repositories that belong to the org
#<0------------------------------------- comment.line.number-sign
# and issues that belong to those repositories
#<0------------------------------------------- comment.line.number-sign
test "organization members can read repos and issues" {
#<0---------------------------------------------------- meta.test-block
#<0- keyword.control
#    ^----------------------------------------------- string.quoted.double
    # Define test data (facts)
#<0--------------------------- meta.test-block
#   ^------------------------- comment.line.number-sign
    setup {
#<0-------- meta.test-block
#   ^------ meta.test-setup
#   ^---- keyword.control
        # alice is a member of the "acme" organization
#<0--------------------------------------------------- meta.test-block
#<0--------------------------------------------------- meta.test-setup
#       ^--------------------------------------------- comment.line.number-sign
        has_role(User{"alice"}, "member", Organization{"acme"});
#<0------------------------------------------------------------- meta.test-block
#<0------------------------------------------------------------- meta.test-setup
#       ^------- support.function.rule
#                ^------------ constant.other.object-literal
#                ^--- entity.name.type.resource
#                     ^------ string.quoted.double
#                             ^ punctuation.separator.sequence.list
#                               ^------- string.quoted.double
#                                       ^ punctuation.separator.sequence.list
#                                         ^------------------- constant.other.object-literal
#                                         ^----------- entity.name.type.resource
#                                                      ^----- string.quoted.double
        # The "test-repo" Repository belongs to the "acme" organization
#<0-------------------------------------------------------------------- meta.test-block
#<0-------------------------------------------------------------------- meta.test-setup
#       ^-------------------------------------------------------------- comment.line.number-sign
        has_relation(Repository{"test-repo"}, "organization", Organization{"acme"});
#<0--------------------------------------------------------------------------------- meta.test-block
#<0--------------------------------------------------------------------------------- meta.test-setup
#       ^----------- support.function.rule
#                    ^---------------------- constant.other.object-literal
#                    ^--------- entity.name.type.resource
#                               ^---------- string.quoted.double
#                                           ^ punctuation.separator.sequence.list
#                                             ^------------- string.quoted.double
#                                                           ^ punctuation.separator.sequence.list
#                                                             ^------------------- constant.other.object-literal
#                                                             ^----------- entity.name.type.resource
#                                                                          ^----- string.quoted.double
        # The issue "Issue 1" belongs to the "test-repo" repository
#<0---------------------------------------------------------------- meta.test-block
#<0---------------------------------------------------------------- meta.test-setup
#       ^---------------------------------------------------------- comment.line.number-sign
        has_relation(Issue{"Issue 1"}, "repository", Repository{"test-repo"});
#<0--------------------------------------------------------------------------- meta.test-block
#<0--------------------------------------------------------------------------- meta.test-setup
#       ^----------- support.function.rule
#                    ^--------------- constant.other.object-literal
#                    ^---- entity.name.type.resource
#                          ^-------- string.quoted.double
#                                    ^ punctuation.separator.sequence.list
#                                      ^----------- string.quoted.double
#                                                  ^ punctuation.separator.sequence.list
#                                                    ^---------------------- constant.other.object-literal
#                                                    ^--------- entity.name.type.resource
#                                                               ^---------- string.quoted.double
    }
#<0-- meta.test-block
#<0-- meta.test-setup

    # alice can read the "test-repo" Repository
#<0-------------------------------------------- meta.test-block
#   ^------------------------------------------ comment.line.number-sign
    assert allow(User{"alice"}, "read", Repository{"test-repo"});
#<0-------------------------------------------------------------- meta.test-block
#   ^----- keyword.other
#          ^---- support.function.rule
#                ^------------ constant.other.object-literal
#                ^--- entity.name.type.resource
#                     ^------ string.quoted.double
#                             ^ punctuation.separator.sequence.list
#                               ^----- string.quoted.double
#                                     ^ punctuation.separator.sequence.list
#                                       ^---------------------- constant.other.object-literal
#                                       ^--------- entity.name.type.resource
#                                                  ^---------- string.quoted.double
    # alice can read the issue "Issue 1"
#<0------------------------------------- meta.test-block
#   ^----------------------------------- comment.line.number-sign
    assert allow(User{"alice"}, "read", Issue{"Issue 1"});
#<0------------------------------------------------------- meta.test-block
#   ^----- keyword.other
#          ^---- support.function.rule
#                ^------------ constant.other.object-literal
#                ^--- entity.name.type.resource
#                     ^------ string.quoted.double
#                             ^ punctuation.separator.sequence.list
#                               ^----- string.quoted.double
#                                     ^ punctuation.separator.sequence.list
#                                       ^--------------- constant.other.object-literal
#                                       ^---- entity.name.type.resource
#                                             ^-------- string.quoted.double
    # alice can not write to the "test-repo" Repository
#<0---------------------------------------------------- meta.test-block
#   ^-------------------------------------------------- comment.line.number-sign
    assert_not allow(User{"alice"}, "write", Repository{"test-repo"});
#<0------------------------------------------------------------------- meta.test-block
#   ^--------- keyword.other
#              ^---- support.function.rule
#                    ^------------ constant.other.object-literal
#                    ^--- entity.name.type.resource
#                         ^------ string.quoted.double
#                                 ^ punctuation.separator.sequence.list
#                                   ^------ string.quoted.double
#                                          ^ punctuation.separator.sequence.list
#                                            ^---------------------- constant.other.object-literal
#                                            ^--------- entity.name.type.resource
#                                                       ^---------- string.quoted.double
}
#<0 meta.test-block

