// --- Async and Await ---
//<0 comment.line.double-slash.js
//<0 punctuation.definition.comment.js

async function fetchData(url) {
//<0--------------------------- meta.function.js
//<0- storage.modifier.async.js
//    ^------- storage.type.function.js
//             ^-------- meta.definition.function.js entity.name.function.js
//                      ^---- meta.parameters.js
