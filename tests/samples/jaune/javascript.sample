  try {
//<0--- meta.function.js
//<0--- meta.block.js
//^-- keyword.control.trycatch.js
//    ^ meta.block.js
//    ^ punctuation.definition.block.js
    const response = await fetch(url);
//<0---------------------------------- meta.function.js
//<0---------------------------------- meta.block.js
//<0---------------------------------- meta.block.js
//   ^--- variable.other.readwrite.js
//        ^------- variable.other.readwrite.js
//                 ^ keyword.operator.assignment.js
//                   ^---- keyword.control.flow.js
