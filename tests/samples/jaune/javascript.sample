//                                                  ^ punctuation.terminator.statement.js
    }
//<0- meta.function.js
//<0- meta.block.js
//<0- meta.block.js
//<0- meta.block.js
//  ^ punctuation.definition.block.js
    const data = await response.json();
//<0----------------------------------- meta.function.js
//<0----------------------------------- meta.block.js
//<0----------------------------------- meta.block.js
//   ^--- variable.other.readwrite.js
//        ^--- variable.other.readwrite.js
//             ^ keyword.operator.assignment.js
