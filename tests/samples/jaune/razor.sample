#                   ^-- variable.other.object.property.cs
#                      ^--- meta.tag.structure.p.end.html
#                      ^- punctuation.definition.tag.begin.html
#                        ^ entity.name.tag.html
#                         ^ punctuation.definition.tag.end.html

    i++;
} while (i < people.Length);
