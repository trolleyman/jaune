@inline
//<0--- keyword.other.rel
module BipartiteGraph[M, N]
//<0-- keyword.control.rel
    def node = M; N
//  ^-- keyword.control.rel
//           ^ keyword.other.rel
    def edge = M, N
//  ^-- keyword.control.rel
//           ^ keyword.other.rel
end
//<0 keyword.control.rel

@inline
//<0--- keyword.other.rel
module CycleGraph[N]
//<0-- keyword.control.rel
    def node = N
//  ^-- keyword.control.rel
//           ^ keyword.other.rel
    def edge(a in N, b in N) =
//  ^-- keyword.control.rel
//             ^- keyword.other.rel
//                     ^- keyword.other.rel
//                           ^ keyword.other.rel
            sort[N](x, a)
        and sort[N](y, b)
//      ^-- keyword.other.rel
        and y = x%count[N] + 1
//      ^-- keyword.other.rel
//            ^ keyword.other.rel
//               ^ keyword.other.rel
//                         ^ keyword.other.rel
        from x, y
//      ^--- keyword.other.rel
end
//<0 keyword.control.rel

@inline
//<0--- keyword.other.rel
module GraphProperties[G]
//<0-- keyword.control.rel
    def outdegree[v in G:node] = count[v1 : G:edge(v, v1)] <++ 0
//  ^-- keyword.control.rel
//                  ^- keyword.other.rel
//                      ^---- variable.parameter.rel
//                             ^ keyword.other.rel
//                                           ^---- variable.parameter.rel
//                                                         ^-- keyword.other.rel
    def indegree[v in G:node] = count[v1 : G:edge(v1, v)] <++ 0
//  ^-- keyword.control.rel
//                 ^- keyword.other.rel
//                     ^---- variable.parameter.rel
//                            ^ keyword.other.rel
//                                          ^---- variable.parameter.rel
//                                                        ^-- keyword.other.rel
    def edge_count = count[G:edge] <++ 0
//  ^-- keyword.control.rel
//                 ^ keyword.other.rel
//                          ^---- variable.parameter.rel
//                                 ^-- keyword.other.rel
end
//<0 keyword.control.rel

def cg = CompleteGraph[range[1 ,5, 1]]
