# grammar: source.elixir

# [] can be used, first match returned
#<0----------------------------------- comment.line.number-sign.elixir
#<0 punctuation.definition.comment.elixir
1 = [a: 1, b: 2, a: 3][:a]
#<0 constant.numeric.integer.elixir
# ^ keyword.operator.assignment.elixir
#   ^ punctuation.section.array.elixir
#    ^- constant.other.keywords.elixir
#     ^ punctuation.definition.constant.elixir
#       ^ constant.numeric.integer.elixir
#        ^ punctuation.separator.object.elixir
