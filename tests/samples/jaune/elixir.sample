# an optional default value can be specified
#<0----------------------------------------- comment.line.number-sign.elixir
#<0 punctuation.definition.comment.elixir
# for missing keys
#<0--------------- comment.line.number-sign.elixir
#<0 punctuation.definition.comment.elixir
"missing" = Keyword.get([a: 1, b: 2, a: 3], :c, "missing")
