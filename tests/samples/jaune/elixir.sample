# Keyword.take returns a list of matching pairs
#<0-------------------------------------------- comment.line.number-sign.elixir
#<0 punctuation.definition.comment.elixir
[a: 1, a: 3] = Keyword.take([a: 1, b: 2, a: 3], [:a])
