//                                               ^ keyword.operator.logical.d
//                                                ^------ string.double-quoted-string.d
//                                                 ^---- string.character.d
//                                                        ^ meta.statement.end.d
    writefln("Parallel init: %s msecs", bm[1].total!"msecs");
//  ^------- entity.name.function.d
//           ^------------------------ string.double-quoted-string.d
//            ^------------ string.character.d
//                          ^ string.character.d
//                            ^------ string.character.d
