; grammar: source.ahk2

#z::Run "https://www.autohotkey.com"  ; Win+Z
;<0 hotkey.ahk2
; ^- punctuation.definition.colon
;   ^-- variable.other.ahk2
;   ^-- support.function.ahk2
;       ^--------------------------- string.quoted.ahk2
;       ^ punctuation.definition.string.begin.ahk2
;                                  ^ punctuation.definition.string.end.ahk2
;                                       ^-- variable.other.ahk2
;                                          ^ keyword.operator.ahk2
;                                           ^ variable.other.ahk2

^!n::  ; Ctrl+Alt+N
;<0 hotkey.ahk2
;  ^- punctuation.definition.colon
;        ^--- variable.other.ahk2
;            ^ keyword.operator.ahk2
;             ^-- variable.other.ahk2
;                ^ keyword.operator.ahk2
;                 ^ variable.other.ahk2
{
;<0 punctuation.section.block.begin.ahk2
    if WinExist("Untitled - Notepad")
;   ^- keyword.control.ahk2
;      ^------- entity.name.function.ahk2
;      ^------- support.function.ahk2
;              ^--------------------- meta.parens.ahk2
;              ^ punctuation.section.parens.begin.bracket.round.ahk2
;               ^------------------- string.quoted.ahk2
;               ^ punctuation.definition.string.begin.ahk2
;                                  ^ punctuation.definition.string.end.ahk2
;                                   ^ punctuation.section.parens.end.bracket.round.ahk2
        WinActivate
;       ^---------- variable.other.ahk2
;       ^---------- support.function.ahk2
    else
;   ^--- keyword.control.ahk2
        Run "Notepad"
;       ^-- variable.other.ahk2
;       ^-- support.function.ahk2
;           ^-------- string.quoted.ahk2
;           ^ punctuation.definition.string.begin.ahk2
;                   ^ punctuation.definition.string.end.ahk2
}
;<0 punctuation.section.block.end.ahk2

; https://www.autohotkey.com/docs/v2/Program.htm
; ^---- variable.other.ahk2
;      ^ keyword.operator.ternary.ahk2
;       ^- keyword.operator.ahk2
;         ^-- variable.other.ahk2
;            ^ punctuation.accessor.ahk2
;             ^--------- variable.other.property.ahk2
;                       ^ punctuation.accessor.ahk2
;                        ^-- variable.other.property.ahk2
;                           ^ keyword.operator.ahk2
;                            ^--- variable.other.ahk2
;                                ^ keyword.operator.ahk2
;                                 ^- variable.other.ahk2
;                                   ^ keyword.operator.ahk2
;                                    ^------ variable.other.ahk2
