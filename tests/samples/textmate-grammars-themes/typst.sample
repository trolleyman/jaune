= Fibonacci sequence
//<0---------------- markup.heading.typst
//<0 punctuation.definition.heading.typst
//^----------------- entity.name.section.typst
The Fibonacci sequence is defined through the
recurrence relation $F_n = F_(n-1) + F_(n-2)$.
//                  ^------------------------ string.other.math.typst
//                  ^ punctuation.definition.string.math.typst
//                                          ^ punctuation.definition.string.math.typst
It can also be expressed in _closed form:_
//                          ^------------- markup.italic.typst
//                          ^ punctuation.definition.italic.typst
//                                       ^ punctuation.definition.italic.typst

$ F_n = round(1 / sqrt(5) phi.alt^n), quad
//<0-------------------------------------- string.other.math.typst
//<0 punctuation.definition.string.math.typst
  phi.alt = (1 + sqrt(5)) / 2 $
//<0--------------------------- string.other.math.typst
//                            ^ punctuation.definition.string.math.typst

#let count = 8
//<0 keyword.other.typst
//<0 punctuation.definition.keyword.typst
//   ^---- variable.other.typst
//         ^ keyword.operator.assignment.typst
//           ^ constant.numeric.integer.typst
#let nums = range(1, count + 1)
//<0 keyword.other.typst
//<0 punctuation.definition.keyword.typst
//   ^--- variable.other.typst
//        ^ keyword.operator.assignment.typst
//          ^---- entity.name.function.typst
//               ^ punctuation.definition.group.typst
//                ^ constant.numeric.integer.typst
//                 ^ punctuation.separator.comma.typst
//                   ^---- variable.other.typst
//                         ^ keyword.operator.arithmetic.typst
//                           ^ constant.numeric.integer.typst
//                            ^ punctuation.definition.group.typst
#let fib(n) = (
//<0 keyword.other.typst
//<0 punctuation.definition.keyword.typst
//   ^-- entity.name.function.typst
//      ^ punctuation.definition.group.typst
//       ^ variable.other.typst
//        ^ punctuation.definition.group.typst
//          ^ keyword.operator.assignment.typst
//            ^ meta.group.typst
//            ^ punctuation.definition.group.typst
  if n <= 2 { 1 }
//<0------------- meta.group.typst
//^- keyword.control.conditional.typst
//   ^ variable.other.typst
//     ^- keyword.operator.relational.typst
//        ^ constant.numeric.integer.typst
//          ^---- meta.block.code.typst
//          ^ punctuation.definition.block.code.typst
//            ^ constant.numeric.integer.typst
//              ^ punctuation.definition.block.code.typst
  else { fib(n - 1) + fib(n - 2) }
//<0------------------------------ meta.group.typst
//^--- keyword.control.conditional.typst
//     ^-------------------------- meta.block.code.typst
//     ^ punctuation.definition.block.code.typst
//       ^-- entity.name.function.typst
//          ^ punctuation.definition.group.typst
//           ^ variable.other.typst
//             ^ keyword.operator.arithmetic.typst
//               ^ constant.numeric.integer.typst
//                ^ punctuation.definition.group.typst
//                  ^ keyword.operator.arithmetic.typst
//                    ^-- entity.name.function.typst
//                       ^ punctuation.definition.group.typst
//                        ^ variable.other.typst
//                          ^ keyword.operator.arithmetic.typst
//                            ^ constant.numeric.integer.typst
//                             ^ punctuation.definition.group.typst
//                               ^ punctuation.definition.block.code.typst
)
//<0 meta.group.typst
//<0 punctuation.definition.group.typst

The first #count numbers of the sequence are:
//        ^----- entity.other.interpolated.typst
//        ^ punctuation.definition.variable.typst

#align(center, table(
//<0-- entity.name.function.typst
//<0 punctuation.definition.function.typst
//    ^ punctuation.definition.group.typst
//     ^----- variable.other.typst
//           ^ punctuation.separator.comma.typst
//             ^---- entity.name.function.typst
//                  ^ punctuation.definition.group.typst
  columns: count,
//^------ variable.parameter.typst
//       ^ punctuation.separator.colon.typst
//         ^---- variable.other.typst
//              ^ punctuation.separator.comma.typst
  ..nums.map(n => $F_#n$),
//^- keyword.operator.typst
//  ^--- variable.other.typst
//       ^-- entity.name.function.typst
//          ^ punctuation.definition.group.typst
//           ^ variable.other.typst
//             ^- keyword.operator.typst
//                ^----- string.other.math.typst
//                ^ punctuation.definition.string.math.typst
//                     ^ punctuation.definition.string.math.typst
//                      ^ punctuation.definition.group.typst
//                       ^ punctuation.separator.comma.typst
  ..nums.map(n => str(fib(n))),
//^- keyword.operator.typst
//  ^--- variable.other.typst
//       ^-- entity.name.function.typst
//          ^ punctuation.definition.group.typst
//           ^ variable.other.typst
//             ^- keyword.operator.typst
//                ^-- entity.name.function.typst
//                   ^ punctuation.definition.group.typst
//                    ^-- entity.name.function.typst
//                       ^ punctuation.definition.group.typst
//                        ^ variable.other.typst
//                         ^-- punctuation.definition.group.typst
//                            ^ punctuation.separator.comma.typst
))
//<0 punctuation.definition.group.typst

