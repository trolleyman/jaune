undo that: edit.undo()
#<0------ entity.name.tag.talon
#          ^---------- variable.parameter.talon
#          ^-------- entity.name.function.talon
#              ^ punctuation.separator.talon
#                   ^ punctuation.definition.parameters.begin.talon
#                    ^ punctuation.definition.parameters.end.talon
redo that: edit.redo()
#<0------ entity.name.tag.talon
