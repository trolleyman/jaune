# grammar: source.talon

# Compound of action(select, clear, copy, cut, paste, etc.)
#<0-------------------------------------------------------- comment.line.number-sign.talon
# and modifier(word, line, etc.) commands for editing text.
#<0-------------------------------------------------------- comment.line.number-sign.talon
# eg: "select line", "clear all"
#<0----------------------------- comment.line.number-sign.talon
<user.edit_action> <user.edit_modifier>: user.edit_command(edit_action, edit_modifier)
#<0------------------------------------ entity.name.tag.talon
#<0--------------- variable.parameter.talon
#                  ^------------------- variable.parameter.talon
#                                        ^-------------------------------------------- variable.parameter.talon
#                                        ^---------------- entity.name.function.talon
#                                            ^ punctuation.separator.talon
#                                                         ^ punctuation.definition.parameters.begin.talon
#                                                          ^---------- variable.parameter.talon
#                                                                     ^ punctuation.separator.talon
#                                                                       ^------------ variable.parameter.talon
#                                                                                    ^ punctuation.definition.parameters.end.talon

# Zoom
#<0--- comment.line.number-sign.talon
zoom in: edit.zoom_in()
#<0---- entity.name.tag.talon
#        ^------------- variable.parameter.talon
#        ^----------- entity.name.function.talon
#            ^ punctuation.separator.talon
#                    ^ punctuation.definition.parameters.begin.talon
#                     ^ punctuation.definition.parameters.end.talon
zoom out: edit.zoom_out()
#<0----- entity.name.tag.talon
#         ^-------------- variable.parameter.talon
#         ^------------ entity.name.function.talon
#             ^ punctuation.separator.talon
#                      ^ punctuation.definition.parameters.begin.talon
#                       ^ punctuation.definition.parameters.end.talon
zoom reset: edit.zoom_reset()
#<0------- entity.name.tag.talon
#           ^---------------- variable.parameter.talon
#           ^-------------- entity.name.function.talon
#               ^ punctuation.separator.talon
#                          ^ punctuation.definition.parameters.begin.talon
#                           ^ punctuation.definition.parameters.end.talon

# Searching
#<0-------- comment.line.number-sign.talon
find it: edit.find()
#<0---- entity.name.tag.talon
#        ^---------- variable.parameter.talon
#        ^-------- entity.name.function.talon
#            ^ punctuation.separator.talon
#                 ^ punctuation.definition.parameters.begin.talon
#                  ^ punctuation.definition.parameters.end.talon
next one: edit.find_next()
#<0----- entity.name.tag.talon
#         ^--------------- variable.parameter.talon
#         ^------------- entity.name.function.talon
#             ^ punctuation.separator.talon
#                       ^ punctuation.definition.parameters.begin.talon
#                        ^ punctuation.definition.parameters.end.talon

# Navigation
#<0--------- comment.line.number-sign.talon

# The reason for these spoken forms is that "page up" and "page down"
#<0------------------------------------------------------------------ comment.line.number-sign.talon
#are globally defined as keys.
#<0--------------------------- comment.line.number-sign.talon
scroll up: edit.page_up()
#<0------ entity.name.tag.talon
#          ^------------- variable.parameter.talon
#          ^----------- entity.name.function.talon
#              ^ punctuation.separator.talon
#                      ^ punctuation.definition.parameters.begin.talon
#                       ^ punctuation.definition.parameters.end.talon
scroll down: edit.page_down()
#<0-------- entity.name.tag.talon
#            ^--------------- variable.parameter.talon
#            ^------------- entity.name.function.talon
#                ^ punctuation.separator.talon
#                          ^ punctuation.definition.parameters.begin.talon
#                           ^ punctuation.definition.parameters.end.talon

# go left, go left left down, go 5 left 2 down
#<0------------------------------------------- comment.line.number-sign.talon
# go word left, go 2 words right
#<0----------------------------- comment.line.number-sign.talon
go <user.navigation_step>+: user.perform_navigation_steps(navigation_step_list)
#<0----------------------- entity.name.tag.talon
#  ^--------------------- variable.parameter.talon
#                           ^-------------------------------------------------- variable.parameter.talon
#                           ^---------------------------- entity.name.function.talon
#                               ^ punctuation.separator.talon
#                                                        ^ punctuation.definition.parameters.begin.talon
#                                                         ^------------------- variable.parameter.talon
#                                                                        ^---- constant.numeric.talon
#                                                                        ^ keyword.operator.talon
#                                                                             ^ punctuation.definition.parameters.end.talon

go line start | head: edit.line_start()
#<0----------------- entity.name.tag.talon
#             ^ punctuation.separator.talon
#                     ^---------------- variable.parameter.talon
#                     ^-------------- entity.name.function.talon
#                         ^ punctuation.separator.talon
#                                    ^ punctuation.definition.parameters.begin.talon
#                                     ^ punctuation.definition.parameters.end.talon
go line end | tail: edit.line_end()
#<0--------------- entity.name.tag.talon
#           ^ punctuation.separator.talon
#                   ^-------------- variable.parameter.talon
#                   ^------------ entity.name.function.talon
#                       ^ punctuation.separator.talon
#                                ^ punctuation.definition.parameters.begin.talon
#                                 ^ punctuation.definition.parameters.end.talon

go way left:
#<0-------- entity.name.tag.talon
    edit.line_start()
#   ^---------------- variable.parameter.talon
#   ^-------------- entity.name.function.talon
#       ^ punctuation.separator.talon
#                  ^ punctuation.definition.parameters.begin.talon
#                   ^ punctuation.definition.parameters.end.talon
    edit.line_start()
#   ^---------------- variable.parameter.talon
#   ^-------------- entity.name.function.talon
#       ^ punctuation.separator.talon
#                  ^ punctuation.definition.parameters.begin.talon
#                   ^ punctuation.definition.parameters.end.talon
go way right: edit.line_end()
#<0--------- entity.name.tag.talon
#             ^-------------- variable.parameter.talon
#             ^------------ entity.name.function.talon
#                 ^ punctuation.separator.talon
#                          ^ punctuation.definition.parameters.begin.talon
#                           ^ punctuation.definition.parameters.end.talon
go way up: edit.file_start()
#<0------ entity.name.tag.talon
#          ^---------------- variable.parameter.talon
#          ^-------------- entity.name.function.talon
#              ^ punctuation.separator.talon
#                         ^ punctuation.definition.parameters.begin.talon
#                          ^ punctuation.definition.parameters.end.talon
go way down: edit.file_end()
#<0-------- entity.name.tag.talon
#            ^-------------- variable.parameter.talon
#            ^------------ entity.name.function.talon
#                ^ punctuation.separator.talon
#                         ^ punctuation.definition.parameters.begin.talon
#                          ^ punctuation.definition.parameters.end.talon

go top: edit.file_start()
#<0--- entity.name.tag.talon
#       ^---------------- variable.parameter.talon
#       ^-------------- entity.name.function.talon
#           ^ punctuation.separator.talon
#                      ^ punctuation.definition.parameters.begin.talon
#                       ^ punctuation.definition.parameters.end.talon
go bottom: edit.file_end()
#<0------ entity.name.tag.talon
#          ^-------------- variable.parameter.talon
#          ^------------ entity.name.function.talon
#              ^ punctuation.separator.talon
#                       ^ punctuation.definition.parameters.begin.talon
#                        ^ punctuation.definition.parameters.end.talon

go page up: edit.page_up()
#<0------- entity.name.tag.talon
#           ^------------- variable.parameter.talon
#           ^----------- entity.name.function.talon
#               ^ punctuation.separator.talon
#                       ^ punctuation.definition.parameters.begin.talon
#                        ^ punctuation.definition.parameters.end.talon
go page down: edit.page_down()
#<0--------- entity.name.tag.talon
#             ^--------------- variable.parameter.talon
#             ^------------- entity.name.function.talon
#                 ^ punctuation.separator.talon
#                           ^ punctuation.definition.parameters.begin.talon
#                            ^ punctuation.definition.parameters.end.talon

# Selecting
#<0-------- comment.line.number-sign.talon

select left: edit.extend_left()
#<0-------- entity.name.tag.talon
#            ^----------------- variable.parameter.talon
#            ^--------------- entity.name.function.talon
#                ^ punctuation.separator.talon
#                            ^ punctuation.definition.parameters.begin.talon
#                             ^ punctuation.definition.parameters.end.talon
select right: edit.extend_right()
#<0--------- entity.name.tag.talon
#             ^------------------ variable.parameter.talon
#             ^---------------- entity.name.function.talon
#                 ^ punctuation.separator.talon
#                              ^ punctuation.definition.parameters.begin.talon
#                               ^ punctuation.definition.parameters.end.talon
select up: edit.extend_line_up()
#<0------ entity.name.tag.talon
#          ^-------------------- variable.parameter.talon
#          ^------------------ entity.name.function.talon
#              ^ punctuation.separator.talon
#                             ^ punctuation.definition.parameters.begin.talon
#                              ^ punctuation.definition.parameters.end.talon
select down: edit.extend_line_down()
#<0-------- entity.name.tag.talon
#            ^---------------------- variable.parameter.talon
#            ^-------------------- entity.name.function.talon
#                ^ punctuation.separator.talon
#                                 ^ punctuation.definition.parameters.begin.talon
#                                  ^ punctuation.definition.parameters.end.talon

select word left: edit.extend_word_left()
#<0------------- entity.name.tag.talon
#                 ^---------------------- variable.parameter.talon
#                 ^-------------------- entity.name.function.talon
#                     ^ punctuation.separator.talon
#                                      ^ punctuation.definition.parameters.begin.talon
#                                       ^ punctuation.definition.parameters.end.talon
select word right: edit.extend_word_right()
#<0-------------- entity.name.tag.talon
#                  ^----------------------- variable.parameter.talon
#                  ^--------------------- entity.name.function.talon
#                      ^ punctuation.separator.talon
#                                        ^ punctuation.definition.parameters.begin.talon
#                                         ^ punctuation.definition.parameters.end.talon

# Indentation
#<0---------- comment.line.number-sign.talon
indent [more]: edit.indent_more()
#<0---------- entity.name.tag.talon
#              ^----------------- variable.parameter.talon
#              ^--------------- entity.name.function.talon
#                  ^ punctuation.separator.talon
#                              ^ punctuation.definition.parameters.begin.talon
#                               ^ punctuation.definition.parameters.end.talon
(indent less | out dent): edit.indent_less()
#<0--------------------- entity.name.tag.talon
#<0 punctuation.definition.parameters.begin.talon
#            ^ punctuation.separator.talon
#                      ^ punctuation.definition.parameters.end.talon
#                         ^----------------- variable.parameter.talon
#                         ^--------------- entity.name.function.talon
#                             ^ punctuation.separator.talon
#                                         ^ punctuation.definition.parameters.begin.talon
#                                          ^ punctuation.definition.parameters.end.talon

# Delete
#<0----- comment.line.number-sign.talon
clear left: edit.delete()
#<0------- entity.name.tag.talon
#           ^------------ variable.parameter.talon
#           ^---------- entity.name.function.talon
#               ^ punctuation.separator.talon
#                      ^ punctuation.definition.parameters.begin.talon
#                       ^ punctuation.definition.parameters.end.talon
clear right: user.delete_right()
#<0-------- entity.name.tag.talon
#            ^------------------ variable.parameter.talon
#            ^---------------- entity.name.function.talon
#                ^ punctuation.separator.talon
#                             ^ punctuation.definition.parameters.begin.talon
#                              ^ punctuation.definition.parameters.end.talon

clear up:
#<0----- entity.name.tag.talon
    edit.extend_line_up()
#   ^-------------------- variable.parameter.talon
#   ^------------------ entity.name.function.talon
#       ^ punctuation.separator.talon
#                      ^ punctuation.definition.parameters.begin.talon
#                       ^ punctuation.definition.parameters.end.talon
    edit.delete()
#   ^------------ variable.parameter.talon
#   ^---------- entity.name.function.talon
#       ^ punctuation.separator.talon
#              ^ punctuation.definition.parameters.begin.talon
#               ^ punctuation.definition.parameters.end.talon

clear down:
#<0------- entity.name.tag.talon
    edit.extend_line_down()
#   ^---------------------- variable.parameter.talon
#   ^-------------------- entity.name.function.talon
#       ^ punctuation.separator.talon
#                        ^ punctuation.definition.parameters.begin.talon
#                         ^ punctuation.definition.parameters.end.talon
    edit.delete()
#   ^------------ variable.parameter.talon
#   ^---------- entity.name.function.talon
#       ^ punctuation.separator.talon
#              ^ punctuation.definition.parameters.begin.talon
#               ^ punctuation.definition.parameters.end.talon

clear word left:
#<0------------ entity.name.tag.talon
    edit.extend_word_left()
#   ^---------------------- variable.parameter.talon
#   ^-------------------- entity.name.function.talon
#       ^ punctuation.separator.talon
#                        ^ punctuation.definition.parameters.begin.talon
#                         ^ punctuation.definition.parameters.end.talon
    edit.delete()
#   ^------------ variable.parameter.talon
#   ^---------- entity.name.function.talon
#       ^ punctuation.separator.talon
#              ^ punctuation.definition.parameters.begin.talon
#               ^ punctuation.definition.parameters.end.talon

clear word right:
#<0------------- entity.name.tag.talon
    edit.extend_word_right()
#   ^----------------------- variable.parameter.talon
#   ^--------------------- entity.name.function.talon
#       ^ punctuation.separator.talon
#                         ^ punctuation.definition.parameters.begin.talon
#                          ^ punctuation.definition.parameters.end.talon
    edit.delete()
#   ^------------ variable.parameter.talon
#   ^---------- entity.name.function.talon
#       ^ punctuation.separator.talon
#              ^ punctuation.definition.parameters.begin.talon
#               ^ punctuation.definition.parameters.end.talon

# Copy
