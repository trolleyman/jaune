# Paste
#<0---- comment.line.number-sign.talon
(pace | paste) that: edit.paste()
#<0---------------- entity.name.tag.talon
#<0 punctuation.definition.parameters.begin.talon
#     ^ punctuation.separator.talon
#            ^ punctuation.definition.parameters.end.talon
#                    ^----------- variable.parameter.talon
#                    ^--------- entity.name.function.talon
#                        ^ punctuation.separator.talon
#                              ^ punctuation.definition.parameters.begin.talon
#                               ^ punctuation.definition.parameters.end.talon
(pace | paste) enter:
#<0----------------- entity.name.tag.talon
#<0 punctuation.definition.parameters.begin.talon
#     ^ punctuation.separator.talon
#            ^ punctuation.definition.parameters.end.talon
    edit.paste()
#   ^----------- variable.parameter.talon
#   ^--------- entity.name.function.talon
#       ^ punctuation.separator.talon
#             ^ punctuation.definition.parameters.begin.talon
#              ^ punctuation.definition.parameters.end.talon
    key(enter)
#   ^--------- entity.name.function.talon
#      ^ punctuation.definition.parameters.begin.talon
#       ^---- variable.parameter.talon
#            ^ punctuation.definition.parameters.key.talon
paste match: edit.paste_match_style()
#<0-------- entity.name.tag.talon
#            ^----------------------- variable.parameter.talon
#            ^--------------------- entity.name.function.talon
#                ^ punctuation.separator.talon
#                                  ^ punctuation.definition.parameters.begin.talon
#                                   ^ punctuation.definition.parameters.end.talon

# Duplication
#<0---------- comment.line.number-sign.talon
clone that: edit.selection_clone()
#<0------- entity.name.tag.talon
#           ^--------------------- variable.parameter.talon
#           ^------------------- entity.name.function.talon
#               ^ punctuation.separator.talon
#                               ^ punctuation.definition.parameters.begin.talon
#                                ^ punctuation.definition.parameters.end.talon
clone line: edit.line_clone()
#<0------- entity.name.tag.talon
#           ^---------------- variable.parameter.talon
#           ^-------------- entity.name.function.talon
#               ^ punctuation.separator.talon
#                          ^ punctuation.definition.parameters.begin.talon
#                           ^ punctuation.definition.parameters.end.talon

# Insert new line
#<0-------------- comment.line.number-sign.talon
new line above: edit.line_insert_up()
#<0----------- entity.name.tag.talon
#               ^-------------------- variable.parameter.talon
#               ^------------------ entity.name.function.talon
#                   ^ punctuation.separator.talon
#                                  ^ punctuation.definition.parameters.begin.talon
#                                   ^ punctuation.definition.parameters.end.talon
new line below | slap: edit.line_insert_down()
#<0------------------ entity.name.tag.talon
#              ^ punctuation.separator.talon
#                      ^---------------------- variable.parameter.talon
#                      ^-------------------- entity.name.function.talon
#                          ^ punctuation.separator.talon
#                                           ^ punctuation.definition.parameters.begin.talon
#                                            ^ punctuation.definition.parameters.end.talon

# Insert padding with optional symbols
#<0----------------------------------- comment.line.number-sign.talon
(pad | padding): user.insert_between(" ", " ")
#<0------------ entity.name.tag.talon
#<0 punctuation.definition.parameters.begin.talon
#    ^ punctuation.separator.talon
#             ^ punctuation.definition.parameters.end.talon
#                ^---------------------------- variable.parameter.talon
#                ^------------------ entity.name.function.talon
#                    ^ punctuation.separator.talon
#                                   ^ punctuation.definition.parameters.begin.talon
#                                    ^-- string.quoted.double.talon
#                                    ^ punctuation.definition.string.begin.talon
#                                      ^ punctuation.definition.string.end.talon
#                                       ^ punctuation.separator.talon
#                                         ^-- string.quoted.double.talon
#                                         ^ punctuation.definition.string.begin.talon
#                                           ^ punctuation.definition.string.end.talon
#                                            ^ punctuation.definition.parameters.end.talon
(pad | padding) <user.symbol_key>+:
#<0------------------------------- entity.name.tag.talon
#<0 punctuation.definition.parameters.begin.talon
#    ^ punctuation.separator.talon
#             ^ punctuation.definition.parameters.end.talon
#               ^---------------- variable.parameter.talon
    insert(" ")
#   ^---------- variable.parameter.talon
#   ^----- entity.name.function.talon
#         ^ punctuation.definition.parameters.begin.talon
#          ^-- string.quoted.double.talon
#          ^ punctuation.definition.string.begin.talon
#            ^ punctuation.definition.string.end.talon
#             ^ punctuation.definition.parameters.end.talon
    user.insert_many(symbol_key_list)
#   ^-------------------------------- variable.parameter.talon
#   ^--------------- entity.name.function.talon
#       ^ punctuation.separator.talon
#                   ^ punctuation.definition.parameters.begin.talon
#                    ^-------------- variable.parameter.talon
#                              ^---- constant.numeric.talon
#                              ^ keyword.operator.talon
#                                   ^ punctuation.definition.parameters.end.talon
    insert(" ")
#   ^---------- variable.parameter.talon
#   ^----- entity.name.function.talon
#         ^ punctuation.definition.parameters.begin.talon
#          ^-- string.quoted.double.talon
#          ^ punctuation.definition.string.begin.talon
#            ^ punctuation.definition.string.end.talon
#             ^ punctuation.definition.parameters.end.talon

# Undo/redo
