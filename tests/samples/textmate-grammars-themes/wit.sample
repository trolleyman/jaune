//                                                 ^----- entity.name.type.borrow.handle.wit
//                                                       ^ punctuation.brackets.angle.begin.wit
//                                                        ^--- entity.name.type.id.handle.wit
//                                                            ^ punctuation.brackets.angle.end.wit
//                                                             ^ punctuation.brackets.round.end.wit
//                                                              ^ meta.whitespace.wit
//                                                               ^------- meta.result-list.wit
//                                                               ^- keyword.operator.arrow.skinny.wit
//                                                                 ^ meta.whitespace.wit
//                                                                  ^--- entity.name.type.id.wit
    }
//<0- meta.interface-item.wit
//<0- meta.resource-item.wit
//<0- meta.resource-methods.wit
//<0 meta.whitespace.wit
//  ^ punctuation.brackets.curly.end.wit
}
//<0 meta.interface-item.wit
//<0 punctuation.brackets.curly.end.wit

interface dependent-interface {
//<0--------------------------- meta.interface-item.wit
//<0----- keyword.declaration.interface.interface-item.wit
//<0----- storage.type.wit
//        ^------------------ entity.name.type.id.interface-item.wit
//                            ^ punctuation.brackets.curly.begin.wit
    use shared.{metadata};
//<0---------------------- meta.interface-item.wit
//<0 meta.whitespace.wit
//  ^-------------------- meta.use-item.wit
//  ^-- keyword.other.use.use-item.wit
//      ^----- entity.name.namespace.id.use-path.wit
//            ^ keyword.operator.namespace-separator.use-item.wit
//             ^ punctuation.brackets.curly.begin.wit
//              ^------- entity.name.type.declaration.use-names-item.use-item.wit
//                      ^ punctuation.brackets.curly.end.wit

    type aliased-metadata = metadata;
//<0--------------------------------- meta.interface-item.wit
//<0 meta.whitespace.wit
//  ^-------------------------------- meta.type-item.wit
//  ^--- keyword.declaration.type.type-item.wit
//  ^--- storage.type.wit
//       ^--------------- entity.name.type.id.type-item.wit
//                        ^ punctuation.equal.wit
//                         ^ meta.whitespace.wit
//                          ^------- entity.name.type.id.wit

    foo: func() -> aliased-metadata;
//<0-------------------------------- meta.interface-item.wit
//<0 meta.whitespace.wit
//  ^------------------------------- meta.func-item.wit
//  ^-- entity.name.function.id.func-item.wit
//  ^-- meta.word.wit
//     ^ keyword.operator.key-value.wit
