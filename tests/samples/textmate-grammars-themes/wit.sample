//       ^--- keyword.other.func.func-type.wit
//           ^- meta.param-list.wit
//           ^ punctuation.brackets.round.begin.wit
//            ^ punctuation.brackets.round.end.wit
//             ^ meta.whitespace.wit
//              ^------------------- meta.result-list.wit
//              ^- keyword.operator.arrow.skinny.wit
//                ^ meta.whitespace.wit
//                 ^--------------- entity.name.type.id.wit
}
