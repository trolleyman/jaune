// An example interface.
//<0-------------------- comment.line.double-slash.wit
interface shared {
//<0-------------- meta.interface-item.wit
//<0----- keyword.declaration.interface.interface-item.wit
//<0----- storage.type.wit
//        ^----- entity.name.type.id.interface-item.wit
//               ^ punctuation.brackets.curly.begin.wit
    // Examples of various types:
//<0----------------------------- meta.interface-item.wit
//<0----------------------------- comment.line.double-slash.wit

    record metadata {
//<0----------------- meta.interface-item.wit
//<0 meta.whitespace.wit
//  ^---------------- meta.record-item.wit
//  ^----- keyword.declaration.record.record-item.wit
//         ^------- entity.name.type.id.record-item.wit
//                  ^ punctuation.brackets.curly.begin.wit
        a: u32,
//<0----------- meta.interface-item.wit
//<0----------- meta.record-item.wit
//<0---- meta.whitespace.wit
//      ^------ meta.record-fields.wit
//      ^ variable.declaration.id.record-fields.wit
//       ^ keyword.operator.key-value.wit
//        ^ meta.whitespace.wit
//         ^-- entity.name.type.numeric.wit
//            ^ punctuation.comma.wit
        b: string,
//<0-------------- meta.interface-item.wit
//<0-------------- meta.record-item.wit
//<0---- meta.whitespace.wit
//      ^--------- meta.record-fields.wit
//      ^ variable.declaration.id.record-fields.wit
//       ^ keyword.operator.key-value.wit
//        ^ meta.whitespace.wit
//         ^----- entity.name.type.string.wit
//               ^ punctuation.comma.wit
    }
//<0- meta.interface-item.wit
//<0- meta.record-item.wit
//<0 meta.whitespace.wit
//  ^ punctuation.brackets.curly.end.wit

    enum errno {
//<0------------ meta.interface-item.wit
//<0 meta.whitespace.wit
//  ^----------- meta.enum-items.wit
//  ^--- keyword.other.enum.enum-items.wit
//       ^---- entity.name.type.id.enum-items.wit
//             ^ punctuation.brackets.curly.begin.wit
        too-big,
//<0------------ meta.interface-item.wit
//<0------------ meta.enum-items.wit
//<0---- meta.whitespace.wit
//      ^------ variable.other.enummember.id.enum-cases.wit
//             ^ punctuation.comma.wit
        too-small,
//<0-------------- meta.interface-item.wit
//<0-------------- meta.enum-items.wit
//<0---- meta.whitespace.wit
//      ^-------- variable.other.enummember.id.enum-cases.wit
//               ^ punctuation.comma.wit
    }
//<0- meta.interface-item.wit
//<0- meta.enum-items.wit
//<0 meta.whitespace.wit
//  ^ punctuation.brackets.curly.end.wit

    // Use `%` to name something after a keyword.
//<0--------------------------------------------- meta.interface-item.wit
//<0--------------------------------------------- comment.line.double-slash.wit
    variant %variant {
//<0------------------ meta.interface-item.wit
//<0 meta.whitespace.wit
//  ^----------------- meta.variant.wit
//  ^------ keyword.other.variant.wit
//           ^------ entity.name.type.id.variant.wit
//                   ^ punctuation.brackets.curly.begin.wit
        baby,
//<0--------- meta.interface-item.wit
//<0--------- meta.variant.wit
//<0---- meta.whitespace.wit
//      ^--- variable.other.enummember.id.enum-cases.wit
//          ^ punctuation.comma.wit
        child(u32), // optional type payload
//<0---------------------------------------- meta.interface-item.wit
//<0---------------------------------------- meta.variant.wit
//<0---- meta.whitespace.wit
//      ^---------- meta.variant-cases.wit
//      ^---- variable.other.enummember.id.variant-cases.wit
//           ^ punctuation.brackets.round.begin.wit
//            ^-- entity.name.type.numeric.wit
//               ^ punctuation.brackets.round.end.wit
//                ^ punctuation.comma.wit
//                 ^------------------------ comment.line.double-slash.wit
        adult,
//<0---------- meta.interface-item.wit
//<0---------- meta.variant.wit
//<0---- meta.whitespace.wit
//      ^---- variable.other.enummember.id.enum-cases.wit
//           ^ punctuation.comma.wit
    }
//<0- meta.interface-item.wit
//<0- meta.variant.wit
//<0 meta.whitespace.wit
//  ^ punctuation.brackets.curly.end.wit

    flags permissions {
//<0------------------- meta.interface-item.wit
//<0 meta.whitespace.wit
