//                  ^---- variable.parameter.id.named-type.wit
//                       ^ keyword.operator.key-value.wit
//                        ^ meta.whitespace.wit
//                         ^------- meta.list.ty.wit
//                         ^--- entity.name.type.list.wit
//                             ^ punctuation.brackets.angle.begin.wit
//                              ^- entity.name.type.numeric.wit
//                                ^ punctuation.brackets.angle.end.wit
//                                 ^ punctuation.brackets.round.end.wit
        read: func(n: u32) -> list<u8>;
//<0----------------------------------- meta.interface-item.wit
//<0----------------------------------- meta.resource-item.wit
//<0----------------------------------- meta.resource-methods.wit
//<0---- meta.whitespace.wit
//      ^------------------------------ meta.func-item.wit
//      ^--- entity.name.function.id.func-item.wit
//      ^--- meta.word.wit
//          ^ keyword.operator.key-value.wit
//           ^ meta.whitespace.wit
//            ^------------------------ meta.function.wit
//            ^--- keyword.other.func.func-type.wit
//                ^------- meta.param-list.wit
//                ^ punctuation.brackets.round.begin.wit
//                 ^----- meta.named-type-list.wit
//                 ^ variable.parameter.id.named-type.wit
//                  ^ keyword.operator.key-value.wit
//                   ^ meta.whitespace.wit
//                    ^-- entity.name.type.numeric.wit
//                       ^ punctuation.brackets.round.end.wit
//                        ^ meta.whitespace.wit
//                         ^----------- meta.result-list.wit
//                         ^- keyword.operator.arrow.skinny.wit
//                           ^ meta.whitespace.wit
//                            ^------- meta.list.ty.wit
//                            ^--- entity.name.type.list.wit
//                                ^ punctuation.brackets.angle.begin.wit
//                                 ^- entity.name.type.numeric.wit
//                                   ^ punctuation.brackets.angle.end.wit
        merge: static func(lhs: borrow<blob>, rhs: borrow<blob>) -> blob;
//<0--------------------------------------------------------------------- meta.interface-item.wit
//<0--------------------------------------------------------------------- meta.resource-item.wit
//<0--------------------------------------------------------------------- meta.resource-methods.wit
//<0---- meta.whitespace.wit
//      ^---------------------------------------------------------------- meta.func-item.wit
//      ^---- entity.name.function.id.func-item.wit
//      ^---- meta.word.wit
//           ^ keyword.operator.key-value.wit
//            ^ meta.whitespace.wit
//             ^--------------------------------------------------------- meta.function.wit
//             ^------ storage.modifier.static.func-item.wit
//                    ^--- keyword.other.func.func-type.wit
//                        ^------------------------------------- meta.param-list.wit
//                        ^ punctuation.brackets.round.begin.wit
//                         ^----------------- meta.named-type-list.wit
//                         ^-- variable.parameter.id.named-type.wit
//                            ^ keyword.operator.key-value.wit
//                             ^ meta.whitespace.wit
//                              ^----------- meta.handle.ty.wit
//                              ^----- entity.name.type.borrow.handle.wit
//                                    ^ punctuation.brackets.angle.begin.wit
