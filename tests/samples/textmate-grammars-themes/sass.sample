# ^----------- support.type.property-name.css.sass.prop.name
#             ^---- meta.property-list.css.sass.prop
#               ^-- meta.property-value.css.sass
#               ^-- support.constant.property-value.css.sass

.warning
#<0----- entity.other.attribute-name.class.css.sass
  @extend %message-shared
# ^------- keyword.control.at-rule.css.sass
#         ^-------------- entity.other.inherited-class.placeholder-selector.css.sass
  border-color: yellow
