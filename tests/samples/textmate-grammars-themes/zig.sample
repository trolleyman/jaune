//        ^--- variable.zig
//             ^ keyword.operator.assignment.zig
//               ^-- variable.zig
//                  ^ punctuation.accessor.zig
//                   ^------ variable.zig
//                          ^ punctuation.accessor.zig
//                           ^-------- variable.zig
//                                    ^ punctuation.terminator.statement.zig

    var list = std.ArrayList(u32).init(ally);
//  ^-- keyword.default.zig
//      ^--- variable.zig
//           ^ keyword.operator.assignment.zig
//             ^-- variable.zig
//                ^ punctuation.accessor.zig
//                 ^-------- entity.name.type.zig
