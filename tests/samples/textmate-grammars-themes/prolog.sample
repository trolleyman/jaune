%           ^ keyword.operator.prolog
%            ^ meta.clause.body.prolog
%             ^ constant.numeric.integer.prolog
%              ^ meta.clause.body.prolog
    %nl,
%<0----- meta.clause.body.prolog
%<0- meta.clause.body.prolog
%   ^--- comment.line.percent-sign.prolog
    draw_char(0, NY).
%<0------------------ meta.clause.body.prolog
%<0----------- meta.clause.body.prolog
%             ^ constant.numeric.integer.prolog
%              ^- meta.clause.body.prolog
%                ^- variable.parameter.uppercase.prolog
%                  ^ meta.clause.body.prolog
%                   ^ keyword.control.clause.bodyend.prolog
draw_char(X, Y) :-
%<0--------------- meta.clause.head.prolog
%<0------ entity.name.function.clause.prolog
%        ^ punctuation.definition.parameters.begin
%         ^ variable.parameter.uppercase.prolog
%            ^ variable.parameter.uppercase.prolog
%             ^ punctuation.definition.parameters.end
%               ^- keyword.control.clause.bodybegin.prolog
    ( X = 0
%<0-------- meta.clause.body.prolog
%<0--- meta.clause.body.prolog
%     ^ variable.parameter.uppercase.prolog
%      ^ meta.clause.body.prolog
%       ^ keyword.operator.prolog
%        ^ meta.clause.body.prolog
%         ^ constant.numeric.integer.prolog
    ->tty_goto(X, Y)
%<0----------------- meta.clause.body.prolog
%<0- meta.clause.body.prolog
%   ^--------------- meta.if.prolog
%   ^- keyword.control.if.prolog
%     ^------- support.function.builtin.prolog
%             ^ meta.if.body.prolog
%              ^ variable.parameter.uppercase.prolog
%               ^- meta.if.body.prolog
%                 ^ variable.parameter.uppercase.prolog
%                  ^ meta.if.body.prolog
    ; true
%<0------- meta.clause.body.prolog
%<0-- meta.if.prolog
%<0- meta.if.body.prolog
%   ^ keyword.control.else.prolog
%    ^ meta.clause.body.prolog
%     ^--- constant.other.atom.simple.prolog
    ),
%<0--- meta.clause.body.prolog
%<0--- meta.clause.body.prolog

    message_lines(YMsgs),
%<0---------------------- meta.clause.body.prolog
%<0--------------- meta.clause.body.prolog
%                 ^---- variable.parameter.uppercase.prolog
%                      ^- meta.clause.body.prolog
    (  Y < YMsgs
%<0------------- meta.clause.body.prolog
%<0---- meta.clause.body.prolog
%      ^ variable.parameter.uppercase.prolog
%       ^ meta.clause.body.prolog
%        ^ keyword.operator.prolog
%         ^ meta.clause.body.prolog
%          ^---- variable.parameter.uppercase.prolog
    -> write(' ')
%<0-------------- meta.clause.body.prolog
%<0- meta.clause.body.prolog
%   ^------------ meta.if.prolog
%   ^- keyword.control.if.prolog
%     ^ meta.if.body.prolog
%      ^---- support.function.builtin.prolog
%           ^ meta.if.body.prolog
%            ^-- constant.other.atom.quoted.prolog
%               ^ meta.if.body.prolog
    ; display_offset(XOff, YOff),
%<0------------------------------ meta.clause.body.prolog
%<0-- meta.if.prolog
%<0- meta.if.body.prolog
%   ^ keyword.control.else.prolog
%    ^--------------- meta.clause.body.prolog
%                    ^--- variable.parameter.uppercase.prolog
%                        ^- meta.clause.body.prolog
%                          ^--- variable.parameter.uppercase.prolog
%                              ^- meta.clause.body.prolog
      XMap is X + XOff,
%<0-------------------- meta.clause.body.prolog
%<0--- meta.clause.body.prolog
%     ^--- variable.parameter.uppercase.prolog
%         ^--- keyword.operator.prolog
%             ^ variable.parameter.uppercase.prolog
%              ^ meta.clause.body.prolog
%               ^ keyword.operator.prolog
%                ^ meta.clause.body.prolog
%                 ^--- variable.parameter.uppercase.prolog
%                     ^ meta.clause.body.prolog
      YMap is Y + YOff,
%<0-------------------- meta.clause.body.prolog
%<0--- meta.clause.body.prolog
%     ^--- variable.parameter.uppercase.prolog
%         ^--- keyword.operator.prolog
%             ^ variable.parameter.uppercase.prolog
%              ^ meta.clause.body.prolog
%               ^ keyword.operator.prolog
%                ^ meta.clause.body.prolog
%                 ^--- variable.parameter.uppercase.prolog
%                     ^ meta.clause.body.prolog
      get_character(XMap, YMap, C),
%<0-------------------------------- meta.clause.body.prolog
%<0----------------- meta.clause.body.prolog
%                   ^--- variable.parameter.uppercase.prolog
%                       ^- meta.clause.body.prolog
%                         ^--- variable.parameter.uppercase.prolog
%                             ^- meta.clause.body.prolog
%                               ^ variable.parameter.uppercase.prolog
%                                ^- meta.clause.body.prolog
      format('~s', [C])
%<0-------------------- meta.clause.body.prolog
%<0--- meta.clause.body.prolog
%     ^----- support.function.builtin.prolog
%           ^ meta.clause.body.prolog
%            ^--- constant.other.atom.quoted.prolog
%                ^-- meta.clause.body.prolog
%                   ^ variable.parameter.uppercase.prolog
%                    ^- meta.clause.body.prolog
    ),
%<0--- meta.clause.body.prolog
%<0--- meta.clause.body.prolog
    NX is X + 1,
%<0------------- meta.clause.body.prolog
%<0- meta.clause.body.prolog
%   ^- variable.parameter.uppercase.prolog
%     ^--- keyword.operator.prolog
%         ^ variable.parameter.uppercase.prolog
%          ^ meta.clause.body.prolog
%           ^ keyword.operator.prolog
%            ^ meta.clause.body.prolog
%             ^ constant.numeric.integer.prolog
%              ^ meta.clause.body.prolog
    draw_char(NX, Y).
%<0------------------ meta.clause.body.prolog
%<0----------- meta.clause.body.prolog
%             ^- variable.parameter.uppercase.prolog
%               ^- meta.clause.body.prolog
%                 ^ variable.parameter.uppercase.prolog
