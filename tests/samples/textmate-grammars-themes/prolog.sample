%<0----- comment.line.percent-sign.prolog

% get_screen(Lines) :-
%<0------------------- meta.clause.body.prolog
%<0------------------- comment.line.percent-sign.prolog
%    map_size(_, YSize),
%<0--------------------- meta.clause.body.prolog
%<0--------------------- comment.line.percent-sign.prolog
