message_lines(2).
%<0-------------- meta.fact.prolog
%<0---------- entity.name.function.fact.prolog
%            ^ punctuation.definition.parameters.begin
%             ^ constant.numeric.integer.prolog
%              ^ punctuation.definition.parameters.end
