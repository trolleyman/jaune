%                                   ^--- variable.parameter.uppercase.prolog
%                                       ^ meta.clause.body.prolog
%                                        ^ keyword.control.clause.bodyend.prolog
display_msgs(Line) :-
%<0------------------ meta.clause.head.prolog
%<0--------- entity.name.function.clause.prolog
%           ^ punctuation.definition.parameters.begin
%            ^--- variable.parameter.uppercase.prolog
%                ^ punctuation.definition.parameters.end
%                  ^- keyword.control.clause.bodybegin.prolog
    message_lines(LineCount),
%<0-------------------------- meta.clause.body.prolog
%<0--------------- meta.clause.body.prolog
%                 ^-------- variable.parameter.uppercase.prolog
%                          ^- meta.clause.body.prolog
    MsgId is LineCount - Line,
%<0--------------------------- meta.clause.body.prolog
%<0- meta.clause.body.prolog
%   ^---- variable.parameter.uppercase.prolog
%        ^--- keyword.operator.prolog
%            ^-------- variable.parameter.uppercase.prolog
%                     ^ meta.clause.body.prolog
%                      ^ keyword.operator.prolog
%                       ^ meta.clause.body.prolog
%                        ^--- variable.parameter.uppercase.prolog
%                            ^ meta.clause.body.prolog
    messages(Messages),
%<0-------------------- meta.clause.body.prolog
%<0---------- meta.clause.body.prolog
%            ^------- variable.parameter.uppercase.prolog
%                    ^- meta.clause.body.prolog
    nth1(MsgId, Messages, Message),
%<0-------------------------------- meta.clause.body.prolog
%<0------ meta.clause.body.prolog
%        ^---- variable.parameter.uppercase.prolog
%             ^- meta.clause.body.prolog
%               ^------- variable.parameter.uppercase.prolog
%                       ^- meta.clause.body.prolog
%                         ^------ variable.parameter.uppercase.prolog
%                                ^- meta.clause.body.prolog
    tty_goto(0, Line),
%<0------------------- meta.clause.body.prolog
%<0- meta.clause.body.prolog
%   ^------- support.function.builtin.prolog
%           ^ meta.clause.body.prolog
%            ^ constant.numeric.integer.prolog
%             ^- meta.clause.body.prolog
%               ^--- variable.parameter.uppercase.prolog
%                   ^- meta.clause.body.prolog
    format('~s', [Message]),
%<0------------------------- meta.clause.body.prolog
%<0- meta.clause.body.prolog
%   ^----- support.function.builtin.prolog
%         ^ meta.clause.body.prolog
%          ^--- constant.other.atom.quoted.prolog
%              ^-- meta.clause.body.prolog
%                 ^------ variable.parameter.uppercase.prolog
%                        ^-- meta.clause.body.prolog
    NextLine is Line + 1,
%<0---------------------- meta.clause.body.prolog
%<0- meta.clause.body.prolog
%   ^------- variable.parameter.uppercase.prolog
%           ^--- keyword.operator.prolog
%               ^--- variable.parameter.uppercase.prolog
%                   ^ meta.clause.body.prolog
%                    ^ keyword.operator.prolog
%                     ^ meta.clause.body.prolog
%                      ^ constant.numeric.integer.prolog
%                       ^ meta.clause.body.prolog
    display_msgs(NextLine).
%<0------------------------ meta.clause.body.prolog
%<0-------------- meta.clause.body.prolog
%                ^------- variable.parameter.uppercase.prolog
%                        ^ meta.clause.body.prolog
