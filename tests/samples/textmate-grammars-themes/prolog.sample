%                               ^ meta.clause.body.prolog
%                                ^ keyword.control.clause.bodyend.prolog
% tile(wall, 0, _).
%<0---------------- comment.line.percent-sign.prolog
% tile(wall, _, 0).
%<0---------------- comment.line.percent-sign.prolog
% tile(wall, X, _) :- map_upper_bound(X, _).
%<0----------------------------------------- comment.line.percent-sign.prolog
% tile(wall, _, Y) :- map_upper_bound(_, Y).
