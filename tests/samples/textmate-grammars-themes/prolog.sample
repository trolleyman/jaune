:- dynamic(player/2, messages/1).
% ^------------------------------ meta.clause.body.prolog
%  ^------ keyword.other
%         ^ meta.clause.body.prolog
%          ^----- constant.other.atom.simple.prolog
%                ^--- meta.clause.body.prolog
%                    ^------- constant.other.atom.simple.prolog
%                            ^-- meta.clause.body.prolog
%                               ^ keyword.control.clause.bodyend.prolog

player(2,3).
%<0--------- meta.fact.prolog
%<0--- entity.name.function.fact.prolog
%     ^ punctuation.definition.parameters.begin
%      ^ constant.numeric.integer.prolog
%        ^ constant.numeric.integer.prolog
%         ^ punctuation.definition.parameters.end
%          ^ keyword.control.fact.end.prolog
messages(["", ""]).
%<0---------------- meta.fact.prolog
%<0----- entity.name.function.fact.prolog
