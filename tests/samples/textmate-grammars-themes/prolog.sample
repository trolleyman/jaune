tile(floor, X, Y) :- in_map(X, Y).
%<0----------------- meta.clause.head.prolog
%<0- entity.name.function.clause.prolog
%   ^ punctuation.definition.parameters.begin
%    ^---- constant.other.atom.simple.prolog
