%                                        ^ meta.clause.body.prolog
%                                         ^ keyword.control.clause.bodyend.prolog

display_msgs(Line) :- message_lines(Line).
%<0------------------ meta.clause.head.prolog
%<0--------- entity.name.function.clause.prolog
%           ^ punctuation.definition.parameters.begin
%            ^--- variable.parameter.uppercase.prolog
%                ^ punctuation.definition.parameters.end
%                  ^- keyword.control.clause.bodybegin.prolog
%                    ^-------------------- meta.clause.body.prolog
