%<0----------------- meta.clause.body.prolog
%<0----------------- comment.line.percent-sign.prolog

move_player(X, Y) :-
%<0----------------- meta.clause.body.prolog
%<0--------- meta.clause.body.prolog
%           ^ variable.parameter.uppercase.prolog
%            ^- meta.clause.body.prolog
%              ^ variable.parameter.uppercase.prolog
%               ^-- meta.clause.body.prolog
%                  ^ keyword.operator.prolog
    player(XCur, YCur),
%<0-------------------- meta.clause.body.prolog
%<0-------- meta.clause.body.prolog
%          ^--- variable.parameter.uppercase.prolog
%              ^- meta.clause.body.prolog
%                ^--- variable.parameter.uppercase.prolog
%                    ^- meta.clause.body.prolog
    XNew is XCur + X,
%<0------------------ meta.clause.body.prolog
%<0- meta.clause.body.prolog
%   ^--- variable.parameter.uppercase.prolog
%       ^--- keyword.operator.prolog
%           ^--- variable.parameter.uppercase.prolog
%               ^ meta.clause.body.prolog
%                ^ keyword.operator.prolog
%                 ^ meta.clause.body.prolog
%                  ^ variable.parameter.uppercase.prolog
%                   ^ meta.clause.body.prolog
    YNew is YCur + Y,
%<0------------------ meta.clause.body.prolog
%<0- meta.clause.body.prolog
%   ^--- variable.parameter.uppercase.prolog
%       ^--- keyword.operator.prolog
%           ^--- variable.parameter.uppercase.prolog
%               ^ meta.clause.body.prolog
%                ^ keyword.operator.prolog
%                 ^ meta.clause.body.prolog
%                  ^ variable.parameter.uppercase.prolog
%                   ^ meta.clause.body.prolog
    (  tile(Tile, XNew, YNew),
%<0--------------------------- meta.clause.body.prolog
%<0--------- meta.clause.body.prolog
%           ^--- variable.parameter.uppercase.prolog
%               ^- meta.clause.body.prolog
%                 ^--- variable.parameter.uppercase.prolog
%                     ^- meta.clause.body.prolog
%                       ^--- variable.parameter.uppercase.prolog
%                           ^- meta.clause.body.prolog
       tile_passable(Tile)
%<0----------------------- meta.clause.body.prolog
%<0------------------ meta.clause.body.prolog
%                    ^--- variable.parameter.uppercase.prolog
%                        ^ meta.clause.body.prolog
    -> retractall(player(_, _)),
%<0----------------------------- meta.clause.body.prolog
%<0- meta.clause.body.prolog
%   ^--------------------------- meta.if.prolog
%   ^- keyword.control.if.prolog
%     ^ meta.if.body.prolog
%      ^--------- support.function.builtin.prolog
%                ^------- meta.if.body.prolog
%                        ^ variable.language.anonymous.prolog
%                         ^- meta.if.body.prolog
%                           ^ variable.language.anonymous.prolog
%                            ^-- meta.if.body.prolog
       asserta(player(XNew, YNew))
%<0------------------------------- meta.clause.body.prolog
%<0------------------------------- meta.if.prolog
%<0------------------------------- meta.fact.prolog
%      ^------ entity.name.function.fact.prolog
%             ^ punctuation.definition.parameters.begin
%                     ^--- variable.parameter.uppercase.prolog
%                           ^--- variable.parameter.uppercase.prolog
    ;  print('Bump!'), nl
%<0---------------------- meta.clause.body.prolog
%<0---------------------- meta.if.prolog
%<0---------------------- meta.fact.prolog
%            ^------ constant.other.atom.quoted.prolog
%                      ^- constant.other.atom.simple.prolog
    ).
%<0--- meta.clause.body.prolog
%<0--- meta.if.prolog
%<0--- meta.fact.prolog
%   ^ punctuation.definition.parameters.end
%    ^ keyword.control.fact.end.prolog

act("\n").
%<0------- meta.clause.body.prolog
%<0------- meta.if.prolog
%<0------- meta.fact.prolog
%<0 entity.name.function.fact.prolog
%  ^ punctuation.definition.parameters.begin
