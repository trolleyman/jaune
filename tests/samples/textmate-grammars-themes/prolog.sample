%                        ^ keyword.control.clause.bodyend.prolog

tile_display(wall, "#").
%<0--------------------- meta.fact.prolog
%<0--------- entity.name.function.fact.prolog
%           ^ punctuation.definition.parameters.begin
%            ^--- constant.other.atom.simple.prolog
%                  ^-- string.quoted.double.prolog
