mainloop :-
%<0-------- meta.clause.body.prolog
%<0-------- meta.if.prolog
%<0-------- meta.clause.head.prolog
%<0----- entity.name.function.clause.prolog
%        ^- keyword.control.clause.bodybegin.prolog
    draw,
%<0------ meta.clause.body.prolog
%<0------ meta.if.prolog
%<0------ meta.clause.body.prolog
%<0- meta.clause.body.prolog
%   ^--- constant.other.atom.simple.prolog
%       ^ meta.clause.body.prolog
    get_single_char(C),
%<0-------------------- meta.clause.body.prolog
%<0-------------------- meta.if.prolog
%<0-------------------- meta.clause.body.prolog
%<0- meta.clause.body.prolog
%   ^-------------- support.function.builtin.prolog
%                  ^ meta.clause.body.prolog
%                   ^ variable.parameter.uppercase.prolog
%                    ^- meta.clause.body.prolog
    (  act([C])
%<0------------ meta.clause.body.prolog
%<0------------ meta.if.prolog
%<0------------ meta.clause.body.prolog
%<0--------- meta.clause.body.prolog
%           ^ variable.parameter.uppercase.prolog
%            ^- meta.clause.body.prolog
    -> true
%<0-------- meta.clause.body.prolog
%<0-------- meta.if.prolog
%<0-------- meta.clause.body.prolog
%<0- meta.clause.body.prolog
%   ^------ meta.if.prolog
%   ^- keyword.control.if.prolog
%     ^ meta.if.body.prolog
%      ^--- constant.other.atom.simple.prolog
    ;  format(codes(Msg), 'unknown character code: ~d', [C]),
%<0---------------------------------------------------------- meta.clause.body.prolog
%<0---------------------------------------------------------- meta.if.prolog
%<0---------------------------------------------------------- meta.clause.body.prolog
%<0-- meta.if.prolog
%<0- meta.if.body.prolog
%   ^ keyword.control.else.prolog
%    ^- meta.clause.body.prolog
%      ^----- support.function.builtin.prolog
%            ^------ meta.clause.body.prolog
%                   ^-- variable.parameter.uppercase.prolog
%                      ^-- meta.clause.body.prolog
%                         ^--------------------------- constant.other.atom.quoted.prolog
%                                                     ^-- meta.clause.body.prolog
%                                                        ^ variable.parameter.uppercase.prolog
%                                                         ^-- meta.clause.body.prolog
       msg(Msg)
%<0------------ meta.clause.body.prolog
%<0------------ meta.if.prolog
%<0------------ meta.clause.body.prolog
%<0-------- meta.clause.body.prolog
%          ^-- variable.parameter.uppercase.prolog
%             ^ meta.clause.body.prolog
    ),
%<0--- meta.clause.body.prolog
%<0--- meta.if.prolog
%<0--- meta.clause.body.prolog
%<0--- meta.clause.body.prolog
    mainloop.
%<0---------- meta.clause.body.prolog
%<0---------- meta.if.prolog
%<0---------- meta.clause.body.prolog
%<0- meta.clause.body.prolog
%   ^------- constant.other.atom.simple.prolog
%           ^ keyword.control.clause.bodyend.prolog

main :- mainloop.
