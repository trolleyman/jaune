--<0 punctuation.spaces.elm



-- UPDATE
--<0----- meta.declaration.module.elm
--^ punctuation.spaces.elm
-- ^----- support.module.elm


type Msg
--<0---- meta.declaration.module.elm
--  ^ punctuation.spaces.elm
--   ^-- support.module.elm
  = Increment
--<0--------- meta.declaration.module.elm
--<0 punctuation.spaces.elm
-- ^ punctuation.spaces.elm
--  ^-------- support.module.elm
  | Decrement
--<0--------- meta.declaration.module.elm
--<0 punctuation.spaces.elm
-- ^ punctuation.spaces.elm
--  ^-------- support.module.elm


update : Msg -> Model -> Model
--<0-------------------------- meta.declaration.module.elm
--    ^ punctuation.spaces.elm
--      ^ punctuation.spaces.elm
--       ^-- support.module.elm
--          ^ punctuation.spaces.elm
--             ^ punctuation.spaces.elm
--              ^---- support.module.elm
--                   ^ punctuation.spaces.elm
--                      ^ punctuation.spaces.elm
--                       ^---- support.module.elm
update msg model =
--<0-------------- meta.declaration.module.elm
--    ^ punctuation.spaces.elm
--        ^ punctuation.spaces.elm
--              ^ punctuation.spaces.elm
  case msg of
--<0--------- meta.declaration.module.elm
--<0 punctuation.spaces.elm
--    ^ punctuation.spaces.elm
--        ^ punctuation.spaces.elm
    Increment ->
--<0------------ meta.declaration.module.elm
--<0 punctuation.spaces.elm
--  ^-------- support.module.elm
--           ^ punctuation.spaces.elm
      model + 1
--<0----------- meta.declaration.module.elm
--<0-- punctuation.spaces.elm
--         ^ punctuation.spaces.elm
--           ^ punctuation.spaces.elm

    Decrement ->
--<0------------ meta.declaration.module.elm
--<0 punctuation.spaces.elm
--  ^-------- support.module.elm
--           ^ punctuation.spaces.elm
      model - 1
--<0----------- meta.declaration.module.elm
--<0-- punctuation.spaces.elm
--         ^ punctuation.spaces.elm
--           ^ punctuation.spaces.elm



-- VIEW
--<0--- meta.declaration.module.elm
--^ punctuation.spaces.elm
-- ^--- support.module.elm


view : Model -> Html Msg
--<0-------------------- meta.declaration.module.elm
--  ^ punctuation.spaces.elm
--    ^ punctuation.spaces.elm
--     ^---- support.module.elm
--          ^ punctuation.spaces.elm
--             ^ punctuation.spaces.elm
--              ^--- support.module.elm
--                  ^ punctuation.spaces.elm
--                   ^-- support.module.elm
view model =
--<0-------- meta.declaration.module.elm
--  ^ punctuation.spaces.elm
--        ^ punctuation.spaces.elm
  div []
--<0---- meta.declaration.module.elm
--<0 punctuation.spaces.elm
--   ^ punctuation.spaces.elm
    [ button [ onClick Decrement ] [ text "-" ]
--<0------------------------------------------- meta.declaration.module.elm
--<0 punctuation.spaces.elm
--   ^ punctuation.spaces.elm
--          ^ punctuation.spaces.elm
--            ^ punctuation.spaces.elm
--               ^---- support.module.elm
--                    ^ punctuation.spaces.elm
--                     ^-------- support.module.elm
--                              ^ punctuation.spaces.elm
--                                ^ punctuation.spaces.elm
--                                  ^ punctuation.spaces.elm
--                                       ^ punctuation.spaces.elm
--                                           ^ punctuation.spaces.elm
    , div [] [ text (String.fromInt model) ]
--<0---------------------------------------- meta.declaration.module.elm
--<0 punctuation.spaces.elm
--   ^ punctuation.spaces.elm
--       ^ punctuation.spaces.elm
--          ^ punctuation.spaces.elm
--            ^ punctuation.spaces.elm
--                 ^ punctuation.spaces.elm
--                  ^--------------------- meta.declaration.exports.elm
--                  ^ punctuation.parens.module-export.elm
--                   ^----- storage.type.elm
--                          ^------ entity.name.function.elm
--                                 ^ punctuation.spaces.elm
--                                  ^---- entity.name.function.elm
--                                       ^ punctuation.parens.module-export.elm
--                                        ^ punctuation.spaces.elm
    , button [ onClick Increment ] [ text "+" ]
--<0------------------------------------------- meta.declaration.module.elm
--<0 punctuation.spaces.elm
--   ^ punctuation.spaces.elm
--          ^ punctuation.spaces.elm
--            ^ punctuation.spaces.elm
--               ^---- support.module.elm
--                    ^ punctuation.spaces.elm
