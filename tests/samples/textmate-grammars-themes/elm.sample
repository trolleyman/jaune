type alias Model = Int
--<0------------------ meta.declaration.module.elm
--  ^ punctuation.spaces.elm
--        ^ punctuation.spaces.elm
--         ^---- support.module.elm
--              ^ punctuation.spaces.elm
--                ^ punctuation.spaces.elm
--                 ^-- support.module.elm


init : Model
--<0-------- meta.declaration.module.elm
--  ^ punctuation.spaces.elm
--    ^ punctuation.spaces.elm
--     ^---- support.module.elm
init =
--<0-- meta.declaration.module.elm
