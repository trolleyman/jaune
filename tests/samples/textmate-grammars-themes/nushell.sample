  ]
#<0 meta.function.body.nushell
#<0 meta.table.nushell
# ^ meta.brace.square.end.nushell

  let query_prefix = "https://api.github.com/search/issues?q=repo:nushell/"
#<0------------------------------------------------------------------------ meta.function.body.nushell
# ^-- keyword.other.nushell
#     ^----------- variable.other.nushell
#                  ^ keyword.control.nushell
#                    ^----------------------------------------------------- string.quoted.double.nushell
#                    ^ punctuation.definition.string.begin.nushell
#                                                                         ^ punctuation.definition.string.end.nushell
  let query_date = (seq date --days 7 -r | get 6)
#<0---------------------------------------------- meta.function.body.nushell
# ^-- keyword.other.nushell
#     ^--------- variable.other.nushell
#                ^ keyword.control.nushell
#                  ^----------------------------- meta.expression.parenthesis.nushell
