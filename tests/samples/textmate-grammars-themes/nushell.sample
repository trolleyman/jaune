#                                       ^ meta.brace.round.end.nushell
#                                         ^ meta.expression.braced.nushell
#                                         ^ punctuation.section.block.begin.bracket.curly.nushell
            print -n $"[($pr.item.title)](char lparen)($pr.item.html_url)(char rparen)"
