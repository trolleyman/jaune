# grammar: source.ssh-config

### default for all ##
#<0------------------- comment.line.number-sign.ssh-config
#<0 punctuation.definition.comment.ssh-config
Host *
#<0- storage.type.ssh-config
#    ^ entity.name.section.ssh-config
#    ^ meta.toc-list.ssh-config
     ForwardAgent no
#    ^----------- keyword.other.ssh-config
#                 ^- constant.language.ssh-config
     ForwardX11 no
#    ^--------- keyword.other.ssh-config
#               ^- constant.language.ssh-config
     ForwardX11Trusted yes
#    ^---------------- keyword.other.ssh-config
#                      ^-- constant.language.ssh-config
     User nixcraft
#    ^--- keyword.other.ssh-config
     Port 22
#    ^--- keyword.other.ssh-config
#         ^- constant.numeric.ssh-config
     Protocol 2
#    ^------- keyword.other.ssh-config
#             ^ constant.numeric.ssh-config
     ServerAliveInterval 60
#    ^------------------ keyword.other.ssh-config
#                        ^- constant.numeric.ssh-config
     ServerAliveCountMax 30
#    ^------------------ keyword.other.ssh-config
#                        ^- constant.numeric.ssh-config

## override as per host ##
#<0----------------------- comment.line.number-sign.ssh-config
#<0 punctuation.definition.comment.ssh-config
Host server1
#<0- storage.type.ssh-config
#    ^------ entity.name.section.ssh-config
#    ^------ meta.toc-list.ssh-config
     HostName server1.cyberciti.biz
#    ^------- keyword.other.ssh-config
     User nixcraft
#    ^--- keyword.other.ssh-config
     Port 4242
#    ^--- keyword.other.ssh-config
#         ^--- constant.numeric.ssh-config
     IdentityFile /nfs/shared/users/nixcraft/keys/server1/id_rsa
#    ^----------- keyword.other.ssh-config

## Home nas server ##
#<0------------------ comment.line.number-sign.ssh-config
#<0 punctuation.definition.comment.ssh-config
Host nas01
#<0- storage.type.ssh-config
#    ^---- entity.name.section.ssh-config
#    ^---- meta.toc-list.ssh-config
     HostName 192.168.1.100
#    ^------- keyword.other.ssh-config
#             ^------------ constant.numeric.ssh-config
     User root
#    ^--- keyword.other.ssh-config
     IdentityFile ~/.ssh/nas01.key
#    ^----------- keyword.other.ssh-config

## Login AWS Cloud ##
#<0------------------ comment.line.number-sign.ssh-config
#<0 punctuation.definition.comment.ssh-config
Host aws.apache
#<0- storage.type.ssh-config
#    ^--------- entity.name.section.ssh-config
#    ^--------- meta.toc-list.ssh-config
     HostName 1.2.3.4
#    ^------- keyword.other.ssh-config
#             ^------ constant.numeric.ssh-config
     User wwwdata
#    ^--- keyword.other.ssh-config
     IdentityFile ~/.ssh/aws.apache.key
#    ^----------- keyword.other.ssh-config

## Login to internal lan server at 192.168.0.251 via our public uk office ssh based gateway using ##
#<0------------------------------------------------------------------------------------------------- comment.line.number-sign.ssh-config
#<0 punctuation.definition.comment.ssh-config
## $ ssh uk.gw.lan ##
#<0------------------ comment.line.number-sign.ssh-config
#<0 punctuation.definition.comment.ssh-config
Host uk.gw.lan uk.lan
#<0- storage.type.ssh-config
#    ^--------------- entity.name.section.ssh-config
#    ^--------------- meta.toc-list.ssh-config
     HostName 192.168.0.251
#    ^------- keyword.other.ssh-config
#             ^------------ constant.numeric.ssh-config
     User nixcraft
#    ^--- keyword.other.ssh-config
     ProxyCommand  ssh nixcraft@gateway.uk.cyberciti.biz nc %h %p 2> /dev/null
#    ^----------- keyword.other.ssh-config
#                                                                 ^ constant.numeric.ssh-config

## Our Us Proxy Server ##
#<0---------------------- comment.line.number-sign.ssh-config
#<0 punctuation.definition.comment.ssh-config
## Forward all local port 3128 traffic to port 3128 on the remote vps1.cyberciti.biz server ##
#<0------------------------------------------------------------------------------------------- comment.line.number-sign.ssh-config
#<0 punctuation.definition.comment.ssh-config
## $ ssh -f -N  proxyus ##
#<0----------------------- comment.line.number-sign.ssh-config
#<0 punctuation.definition.comment.ssh-config
Host proxyus
#<0- storage.type.ssh-config
#    ^------ entity.name.section.ssh-config
#    ^------ meta.toc-list.ssh-config
    HostName vps1.cyberciti.biz
#   ^------- keyword.other.ssh-config
    User breakfree
#   ^--- keyword.other.ssh-config
    IdentityFile ~/.ssh/vps1.cyberciti.biz.key
#   ^----------- keyword.other.ssh-config
    LocalForward 3128 127.0.0.1:3128
#   ^----------- keyword.other.ssh-config
#                ^--- constant.numeric.ssh-config
#                     ^-------- constant.numeric.ssh-config
#                               ^--- constant.numeric.ssh-config

## From https://www.cyberciti.biz/faq/create-ssh-config-file-on-linux-unix/
#<0------------------------------------------------------------------------ comment.line.number-sign.ssh-config
#<0 punctuation.definition.comment.ssh-config
