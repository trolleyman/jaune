// grammar: source.stylus

vendor(prop, args)
//<0------------- meta.function.stylus
//<0-- entity.name.function.stylus
//    ^ punctuation.section.function.css
//         ^- punctuation.separator.parameter.css
//               ^ punctuation.section.function.css
  -webkit-{prop} args
//<0----------------- meta.property-list.css
//        ^----- meta.interpolation.stylus
//        ^ meta.brace.curly
//             ^ meta.brace.curly
  -moz-{prop} args
//<0-------------- meta.property-list.css
//     ^----- meta.interpolation.stylus
//     ^ meta.brace.curly
//          ^ meta.brace.curly
  {prop} args
//<0--------- meta.property-list.css
//^----- meta.interpolation.stylus
//^ meta.brace.curly
//     ^ meta.brace.curly

border-radius()
//<0---------- meta.function.stylus
//<0--------- entity.name.function.stylus
//           ^ punctuation.section.function.css
//            ^ punctuation.section.function.css
  vendor('border-radius', arguments)
//<0-------------------------------- meta.property-list.css
//^-------------------------------- meta.function.stylus
//^----- entity.name.function.stylus
//      ^ punctuation.section.function.css
//       ^-------------- string.quoted.single.css
