box-shadow()
//<0------- meta.function.stylus
//<0------ entity.name.function.stylus
//        ^ punctuation.section.function.css
//         ^ punctuation.section.function.css
  vendor('box-shadow', arguments)
//<0----------------------------- meta.property-list.css
//^----------------------------- meta.function.stylus
//^----- entity.name.function.stylus
//      ^ punctuation.section.function.css
//       ^----------- string.quoted.single.css
