(*             ^----------- emphasis *)
(*                          ^---- string.other.link *)
(*                          ^---- variable.language *)
(*                          ^---- variable.parameter *)
(*                          ^---- emphasis *)
  if david'.human then
(*   ^----- string.other.link *)
(*   ^----- variable.language *)
(*   ^----- variable.parameter *)
(*   ^----- emphasis *)
(*         ^ variable.other.class.js *)
(*         ^ message.error *)
(*         ^ variable.interpolation *)
(*         ^ string.regexp *)
(*          ^---- string.other.link *)
(*          ^---- variable.language *)
(*          ^---- variable.parameter *)
(*          ^---- emphasis *)
    print_endline "david is human"
(*  ^------------ string.other.link *)
(*  ^------------ variable.language *)
(*  ^------------ variable.parameter *)
(*  ^------------ emphasis *)
(*                ^--------------- string *)
(*                ^--------------- beginning.punctuation.definition.quote.markdown *)
  else
    print_endline "david is not human"
(*  ^------------ string.other.link *)
(*  ^------------ variable.language *)
(*  ^------------ variable.parameter *)
(*  ^------------ emphasis *)
(*                ^------------------- string *)
(*                ^------------------- beginning.punctuation.definition.quote.markdown *)
;;
