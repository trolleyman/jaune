(*            ^ variable.interpolation *)
(*            ^ string.regexp *)
  let david' = toggle_human david in
(*    ^----- string.other.link *)
(*    ^----- variable.language *)
(*    ^----- variable.parameter *)
(*    ^----- emphasis *)
(*           ^ variable.other.class.js *)
(*           ^ message.error *)
(*           ^ variable.interpolation *)
