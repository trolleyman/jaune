  br i1 %exitcond.not, label %for.end, label %for.body
; ^- keyword.instruction.llvm
;    ^- storage.type.llvm
;       ^------------ variable.llvm
;                      ^---- storage.type.llvm
;                            ^------- variable.llvm
;                                      ^---- storage.type.llvm
;                                            ^-------- variable.llvm

for.end:
;<0----- entity.name.label.llvm
  %sum.0.lcssa = phi i32 [ 0, %entry ], [ %add, %for.body ]
; ^----------- variable.llvm
