entry:
;<0--- entity.name.label.llvm
  %cmp4 = icmp sgt i32 %length, 0
; ^---- variable.llvm
;         ^--- keyword.instruction.llvm
;              ^-- keyword.instruction.llvm
;                  ^-- storage.type.llvm
;                      ^------ variable.llvm
;                               ^ constant.numeric.integer
  br i1 %cmp4, label %for.body.preheader, label %for.end
