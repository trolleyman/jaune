;              ^---- storage.type.llvm
;                    ^------------------ variable.llvm
;                                         ^---- storage.type.llvm
;                                               ^------- variable.llvm

for.body.preheader:
;<0---------------- entity.name.label.llvm
  %wide.trip.count = zext nneg i32 %length to i64
; ^--------------- variable.llvm
;                    ^--- keyword.instruction.llvm
;                              ^-- storage.type.llvm
;                                  ^------ variable.llvm
;                                          ^- storage.modifier.llvm
;                                             ^-- storage.type.llvm
  br label %for.body
; ^- keyword.instruction.llvm
;    ^---- storage.type.llvm
;          ^-------- variable.llvm

for.body:
;<0------ entity.name.label.llvm
  %indvars.iv = phi i64 [ 0, %for.body.preheader ], [ %indvars.iv.next, %for.body ]
; ^---------- variable.llvm
;               ^-- keyword.instruction.llvm
;                   ^-- storage.type.llvm
;                         ^ constant.numeric.integer
;                            ^------------------ variable.llvm
;                                                     ^--------------- variable.llvm
;                                                                       ^-------- variable.llvm
  %sum.06 = phi i32 [ 0, %for.body.preheader ], [ %add, %for.body ]
; ^------ variable.llvm
;           ^-- keyword.instruction.llvm
;               ^-- storage.type.llvm
;                     ^ constant.numeric.integer
;                        ^------------------ variable.llvm
;                                                 ^--- variable.llvm
;                                                       ^-------- variable.llvm
  %arrayidx = getelementptr inbounds i32, ptr %input, i64 %indvars.iv
; ^-------- variable.llvm
;             ^------------ keyword.instruction.llvm
;                           ^------- keyword.instruction.llvm
;                                    ^-- storage.type.llvm
;                                             ^----- variable.llvm
;                                                     ^-- storage.type.llvm
;                                                         ^---------- variable.llvm
  %0 = load i32, ptr %arrayidx, align 4
; ^- variable.llvm
;      ^--- keyword.instruction.llvm
;           ^-- storage.type.llvm
;                    ^-------- variable.llvm
;                               ^---- storage.modifier.llvm
;                                     ^ constant.numeric.integer
  %add = add nsw i32 %0, %sum.06
; ^--- variable.llvm
;        ^-- keyword.instruction.llvm
;            ^-- keyword.instruction.llvm
;                ^-- storage.type.llvm
;                    ^- variable.llvm
;                        ^------ variable.llvm
  %indvars.iv.next = add nuw nsw i64 %indvars.iv, 1
; ^--------------- variable.llvm
;                    ^-- keyword.instruction.llvm
;                        ^-- keyword.instruction.llvm
;                            ^-- keyword.instruction.llvm
;                                ^-- storage.type.llvm
;                                    ^---------- variable.llvm
;                                                 ^ constant.numeric.integer
  %exitcond.not = icmp eq i64 %indvars.iv.next, %wide.trip.count
; ^------------ variable.llvm
