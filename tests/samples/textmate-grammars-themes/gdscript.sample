#         ^-------------- meta.function-call.gdscript
#         ^------------ entity.name.function.gdscript
#                      ^ punctuation.definition.arguments.begin.gdscript
#                       ^ punctuation.definition.arguments.end.gdscript

    for i in range(1): # `in` is a control keyword
#   ^-- keyword.control.gdscript
#       ^ variable.other.gdscript
#         ^- keyword.control.gdscript
#            ^------- meta.function-call.gdscript
#            ^---- entity.name.function.gdscript
#                 ^ punctuation.definition.arguments.begin.gdscript
#                  ^ meta.function.parameters.gdscript
#                  ^ constant.numeric.integer.gdscript
#                   ^ punctuation.definition.arguments.end.gdscript
#                      ^-------------------------- comment.line.number-sign.gdscript
#                      ^ punctuation.definition.comment.number-sign.gdscript
        print(i in range(1)) # `in` is an operator keyword
#       ^------------------- meta.function-call.gdscript
#       ^---- entity.name.function.gdscript
#            ^ punctuation.definition.arguments.begin.gdscript
#             ^------------ meta.function.parameters.gdscript
#             ^ variable.other.gdscript
