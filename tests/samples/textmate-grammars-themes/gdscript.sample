    await $Button.button_up
#   ^---- keyword.control.gdscript
#         ^------ meta.literal.nodepath.bare.gdscript
#         ^ keyword.control.flow.gdscript
#          ^----- constant.character.escape.gdscript
#                ^ punctuation.accessor.gdscript
