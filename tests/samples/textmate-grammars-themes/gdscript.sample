#                                          ^ punctuation.definition.parameters.end.gdscript
		pass
# ^--- keyword.control.flow.gdscript
	var lambda_b = func(param1, param2=func_a(10, 1.0, 'test')):
#^----------------------------------------------------------- meta.variable.declaration.gdscript
#^-- keyword.language.gdscript
#^-- storage.type.var.gdscript
#    ^------- variable.other.gdscript
#             ^ keyword.operator.assignment.gdscript
#               ^-------------------------------------------- meta.function.gdscript
#               ^--- keyword.language.gdscript
