#                                              ^-- constant.numeric.float.gdscript
#                                                 ^ punctuation.separator.arguments.gdscript
#                                                   ^----- string.quoted.gdscript
#                                                         ^ punctuation.definition.arguments.end.gdscript
#                                                          ^ punctuation.definition.parameters.end.gdscript
		pass
# ^--- keyword.control.flow.gdscript
	var lambda_c = func(param1 = false, param2: bool = false, param3 := false):
#^-------------------------------------------------------------------------- meta.variable.declaration.gdscript
#^-- keyword.language.gdscript
#^-- storage.type.var.gdscript
#    ^------- variable.other.gdscript
#             ^ keyword.operator.assignment.gdscript
#               ^----------------------------------------------------------- meta.function.gdscript
#               ^--- keyword.language.gdscript
#               ^--- storage.type.function.gdscript
#                   ^------------------------------------------------------ meta.function.parameters.gdscript
