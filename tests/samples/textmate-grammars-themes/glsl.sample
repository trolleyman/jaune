//<0 punctuation.section.block.end.bracket.curly.c

vec3 calculateDiffuseLighting(vec3 toLightVector, vec3 normal){
//<0 storage.type.glsl
//   ^-------------------------------------------------------- meta.function.c
//   ^-------------------------------------------------------- meta.function.definition.parameters.c
//   ^----------------------- entity.name.function.c
//                           ^ punctuation.section.parameters.begin.bracket.round.c
//                                 ^------------ variable.parameter.probably.c
//                                              ^ punctuation.separator.delimiter.c
//                                                     ^----- variable.parameter.probably.c
//                                                           ^ punctuation.section.parameters.end.bracket.round.c
//                                                            ^ meta.block.c
//                                                            ^ punctuation.section.block.begin.bracket.curly.c
	float brightness = max(dot(toLightVector, normal), 0.0);
//<0----------------------------------------------------- meta.block.c
//<1-- storage.type.built-in.primitive.c
//                ^ keyword.operator.assignment.c
//                  ^----------------------------------- meta.function-call.c
//                  ^-- entity.name.function.c
//                     ^ punctuation.section.arguments.begin.bracket.round.c
//                      ^-- entity.name.function.c
//                         ^ punctuation.section.arguments.begin.bracket.round.c
//                                       ^ punctuation.separator.delimiter.c
//                                               ^ punctuation.section.arguments.end.bracket.round.c
//                                                ^ punctuation.separator.delimiter.c
//                                                  ^ constant.numeric.decimal.c
//                                                   ^ constant.numeric.decimal.point.c
//                                                    ^ constant.numeric.decimal.c
//                                                     ^ punctuation.section.arguments.end.bracket.round.c
//                                                      ^ punctuation.terminator.statement.c
	return (lightColour * lightBias.x) + (brightness * lightColour * lightBias.y);
//<0--------------------------------------------------------------------------- meta.block.c
//<1--- keyword.control.c
//      ^-------------------------- meta.parens.block.c
//      ^ punctuation.section.parens.begin.bracket.round.c
//                   ^ keyword.operator.c
//                     ^-------- variable.other.object.access.c
