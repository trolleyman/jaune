float generateOffset(float x, float z){
//<0- storage.type.glsl
//    ^------------------------------- meta.function.c
//    ^------------------------------- meta.function.definition.parameters.c
//    ^------------- entity.name.function.c
//                  ^ punctuation.section.parameters.begin.bracket.round.c
//                   ^---- storage.type.built-in.primitive.c
//                         ^ variable.parameter.probably.c
//                          ^ punctuation.separator.delimiter.c
//                            ^---- storage.type.built-in.primitive.c
//                                  ^ variable.parameter.probably.c
//                                   ^ punctuation.section.parameters.end.bracket.round.c
//                                    ^ meta.block.c
//                                    ^ punctuation.section.block.begin.bracket.curly.c
	float radiansX = (x / waveLength + waveTime) * 2.0 * PI;
//<0----------------------------------------------------- meta.block.c
//<1-- storage.type.built-in.primitive.c
//              ^ keyword.operator.assignment.c
//                ^-------------------------- meta.parens.block.c
//                ^ punctuation.section.parens.begin.bracket.round.c
//                   ^ keyword.operator.c
//                                ^ keyword.operator.c
//                                          ^ punctuation.section.parens.end.bracket.round.c
//                                            ^ keyword.operator.c
//                                              ^ constant.numeric.decimal.c
//                                               ^ constant.numeric.decimal.point.c
//                                                ^ constant.numeric.decimal.c
//                                                  ^ keyword.operator.c
//                                                      ^ punctuation.terminator.statement.c
	float radiansZ = (z / waveLength + waveTime) * 2.0 * PI;
//<0----------------------------------------------------- meta.block.c
//<1-- storage.type.built-in.primitive.c
//              ^ keyword.operator.assignment.c
//                ^-------------------------- meta.parens.block.c
//                ^ punctuation.section.parens.begin.bracket.round.c
//                   ^ keyword.operator.c
//                                ^ keyword.operator.c
//                                          ^ punctuation.section.parens.end.bracket.round.c
//                                            ^ keyword.operator.c
//                                              ^ constant.numeric.decimal.c
//                                               ^ constant.numeric.decimal.point.c
//                                                ^ constant.numeric.decimal.c
//                                                  ^ keyword.operator.c
//                                                      ^ punctuation.terminator.statement.c
	return waveAmplitude * 0.5 * (sin(radiansZ) + cos(radiansX));
//<0---------------------------------------------------------- meta.block.c
//<1--- keyword.control.c
//                    ^ keyword.operator.c
//                      ^ constant.numeric.decimal.c
//                       ^ constant.numeric.decimal.point.c
//                        ^ constant.numeric.decimal.c
//                          ^ keyword.operator.c
