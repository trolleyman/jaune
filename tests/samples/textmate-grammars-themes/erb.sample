#<0------- string.quoted.double.ts
#   ^ keyword.operator.relational.ts
#    ^--- variable.other.readwrite.ts
#        ^ keyword.operator.relational.ts

      <h1><%= @name %> (<%= @code %>)</h1>
#<0--------------------------------------- string.quoted.double.ts
#<0--------------------------------------- string.quoted.double.ts
#     ^ keyword.operator.relational.ts
#      ^- variable.other.readwrite.ts
#        ^- keyword.operator.relational.ts
#          ^- keyword.operator.assignment.compound.ts
#              ^--- variable.other.readwrite.ts
#                   ^ keyword.operator.arithmetic.ts
