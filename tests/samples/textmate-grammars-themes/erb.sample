  def initialize( code, name, desc, cost )
#<0--------------------------------------- string.quoted.double.ts
#<0--------------------------------------- string.quoted.double.ts
# ^-- variable.other.readwrite.ts
    @code = code
#<0------------- string.quoted.double.ts
#<0------------- string.quoted.double.ts
#    ^--- variable.other.readwrite.ts
#         ^ keyword.operator.assignment.ts
#           ^--- variable.other.readwrite.ts
    @name = name
#<0------------- string.quoted.double.ts
#<0------------- string.quoted.double.ts
#    ^--- variable.other.readwrite.ts
#         ^ keyword.operator.assignment.ts
#           ^--- variable.other.readwrite.ts
    @desc = desc
