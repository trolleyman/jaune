  end
#<0-- string.quoted.double.ts
#<0-- string.quoted.double.ts
# ^-- variable.other.readwrite.ts

  def add_feature( feature )
#<0------------------------- string.quoted.double.ts
#<0------------------------- string.quoted.double.ts
# ^-- variable.other.readwrite.ts
    @features << feature
#<0--------------------- string.quoted.double.ts
#<0--------------------- string.quoted.double.ts
#    ^------- variable.other.readwrite.ts
#             ^- keyword.operator.bitwise.shift.ts
#                ^------ variable.other.readwrite.ts
  end
#<0-- string.quoted.double.ts
#<0-- string.quoted.double.ts
# ^-- variable.other.readwrite.ts

