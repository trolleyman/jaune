// grammar: source.proto

syntax = "proto3";
//<0-- keyword.other.proto
//     ^ keyword.operator.assignment.proto
//       ^------- string.quoted.double.proto.syntax
//               ^ punctuation.terminator.proto

package mypackage.books.v1;
//<0--- keyword.other.proto
//      ^----------------- string.unquoted.proto.package
//                        ^ punctuation.terminator.proto

import "google/protobuf/empty.proto";
//<0-- keyword.other.proto
//     ^---------------------------- string.quoted.double.proto.import
//                                  ^ punctuation.terminator.proto
import "google/api/field_behavior.proto";
//<0-- keyword.other.proto
//     ^-------------------------------- string.quoted.double.proto.import
//                                      ^ punctuation.terminator.proto

import "google/api/annotations.proto";
//<0-- keyword.other.proto
//     ^----------------------------- string.quoted.double.proto.import
//                                   ^ punctuation.terminator.proto

option go_package = "mypackage.books.v1/books";
//<0-- keyword.other.proto
//     ^--------- support.other.proto
//                ^ keyword.operator.assignment.proto
//                  ^------------------------- string.quoted.double.proto
//                                            ^ punctuation.terminator.proto

// Book service
//<0----------- comment.line.double-slash.proto
service BooksService {
//<0--- keyword.other.proto
//      ^----------- entity.name.class.message.proto
	// Get a book.
//<1----------- comment.line.double-slash.proto
	rpc GetBook(GetBookRequest) returns (Book) {
//<1 keyword.other.proto
//   ^------ entity.name.function
//           ^------------- entity.name.class.proto
//                           ^------ keyword.other.proto
//                                    ^--- entity.name.class.proto
		option (google.api.http) = {
//^----- keyword.other.proto
//       ^---------------- support.other.proto
//                  ^---- support.other.proto
//                         ^ keyword.operator.assignment.proto
			get: "/resources/store/v1/{name=books/*}"
// ^-- keyword.other.proto
//    ^ punctuation.separator.key-value.proto
//      ^----------------------------------- string.quoted.double.proto
		};
// ^ punctuation.terminator.proto
	}
}

// The definition of a book resource.
//<0--------------------------------- comment.line.double-slash.proto
message Book {
//<0--- keyword.other.proto
//      ^--- entity.name.class.message.proto
	// The name of the book.
//<1--------------------- comment.line.double-slash.proto
	// Format: books/{book}.
//<1--------------------- comment.line.double-slash.proto
	string name = 1 [(google.api.field_behavior) = OUTPUT_ONLY];
//<1--- storage.type.proto
//      ^--- variable.other.proto
//           ^ keyword.operator.assignment.proto
//             ^ constant.numeric.proto
//                ^-------------------------- support.other.proto
//                           ^-------------- support.other.proto
//                                              ^---------- constant.language.proto
//                                                          ^ punctuation.terminator.proto

	// The display name of the book.
//<1----------------------------- comment.line.double-slash.proto
	string display_name = 2 [(google.api.field_behavior) = REQUIRED];
//<1--- storage.type.proto
//      ^----------- variable.other.proto
//                   ^ keyword.operator.assignment.proto
//                     ^ constant.numeric.proto
//                        ^-------------------------- support.other.proto
//                                   ^-------------- support.other.proto
//                                                      ^------- constant.language.proto
//                                                               ^ punctuation.terminator.proto

	// The authors of the book.
//<1------------------------ comment.line.double-slash.proto
	repeated string authors = 3 [(google.api.field_behavior) = REQUIRED];
//<1----- storage.modifier.proto
//        ^----- storage.type.proto
//               ^------ variable.other.proto
//                       ^ keyword.operator.assignment.proto
//                         ^ constant.numeric.proto
//                            ^-------------------------- support.other.proto
//                                       ^-------------- support.other.proto
//                                                          ^------- constant.language.proto
//                                                                   ^ punctuation.terminator.proto

	// The publisher of the book
//<1------------------------- comment.line.double-slash.proto
	string publisher = 4 [(google.api.field_behavior) = OPTIONAL];
//<1--- storage.type.proto
//      ^-------- variable.other.proto
//                ^ keyword.operator.assignment.proto
//                  ^ constant.numeric.proto
//                     ^-------------------------- support.other.proto
//                                ^-------------- support.other.proto
//                                                   ^------- constant.language.proto
//                                                            ^ punctuation.terminator.proto
}

// Request message for [play.me.resources.books.v1.BooksService.GetBook].
//<0--------------------------------------------------------------------- comment.line.double-slash.proto
message GetBookRequest {
//<0--- keyword.other.proto
//      ^------------- entity.name.class.message.proto
	// The book name is the unique identifier across organisations.
//<1------------------------------------------------------------ comment.line.double-slash.proto
	// Format: books/{book}
//<1-------------------- comment.line.double-slash.proto
	string name = 1 [(google.api.field_behavior) = REQUIRED];
//<1--- storage.type.proto
//      ^--- variable.other.proto
//           ^ keyword.operator.assignment.proto
//             ^ constant.numeric.proto
//                ^-------------------------- support.other.proto
//                           ^-------------- support.other.proto
//                                              ^------- constant.language.proto
//                                                       ^ punctuation.terminator.proto
}

// From https://alis.build/guides/how-to-guides/make-your-first-request.html#book-repository-example
//<0------------------------------------------------------------------------------------------------ comment.line.double-slash.proto
