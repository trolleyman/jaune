(with-test (:name :aprof-instance :skipped-on (not :immobile-space))
;           ^---- entity.name.variable.commonlisp
;                 ^-------------- entity.name.variable.commonlisp
;                                 ^---------- entity.name.variable.commonlisp
;                                              ^-- support.function.f.sideeffects.commonlisp
;                                                  ^-------------- entity.name.variable.commonlisp
  (let (seen-this seen-that)
;  ^-- keyword.control.commonlisp
    (dolist (line (split-string
;    ^----- storage.type.function.m.nosideeffects.commonlisp
                   (with-output-to-string (s)
;                   ^-------------------- storage.type.function.m.sideeffects.commonlisp
                     (sb-aprof:aprof-run #'make-structs :stream s))
