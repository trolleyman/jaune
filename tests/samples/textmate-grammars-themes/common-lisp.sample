;                                        ^- variable.other.constant.sharpsign.commonlisp
;                                                       ^------ entity.name.variable.commonlisp
                   #\newline))
;                  ^-------- constant.character.escape.commonlisp
      (when (search "THIS-STRUCT" line) (setq seen-this t))
;      ^--- storage.type.function.m.nosideeffects.commonlisp
;            ^----- support.function.f.sideeffects.commonlisp
;                   ^------------ string.quoted.double.commonlisp
;                   ^ punctuation.definition.string.begin.commonlisp
;                               ^ punctuation.definition.string.end.commonlisp
;                                        ^--- storage.type.function.specialform.commonlisp
;                                                       ^ constant.language.commonlisp
      (when (search "THAT-STRUCT" line) (setq seen-that t)))
;      ^--- storage.type.function.m.nosideeffects.commonlisp
;            ^----- support.function.f.sideeffects.commonlisp
;                   ^------------ string.quoted.double.commonlisp
;                   ^ punctuation.definition.string.begin.commonlisp
;                               ^ punctuation.definition.string.end.commonlisp
;                                        ^--- storage.type.function.specialform.commonlisp
;                                                       ^ constant.language.commonlisp
    (assert (and seen-this seen-that))))
